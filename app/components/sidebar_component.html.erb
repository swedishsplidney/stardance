<aside class="sidebar"
       id="primary-nav"
       data-controller="sidebar-active nav-history"
       data-turbo-permanent
       aria-label="Main">
  <%= link_to root_path, class: "sidebar__logo", "aria-label": "Stardance home", data: { turbo: true } do %>
    <%= image_tag "landing/header/stardance-logo.png", alt: "Hack Club Stardance Challenge", class: "sidebar__logo-img" %>
  <% end %>

  <nav class="sidebar__nav" aria-label="Primary navigation">
    <ul class="sidebar__nav-list">
      <% nav_items.each do |item| %>
        <% link_classes = link_classes_for(item) %>

        <li class="sidebar__nav-item" data-onboarding-target="<%= item[:slug] %>">
          <% icon_block = capture do %>
            <span class="sidebar__nav-icon-wrapper" aria-hidden="true">
              <% case item[:icon] %>
              <% when :avatar %>
                <% avatar_classes = [ "sidebar__nav-avatar", ("sidebar__nav-avatar--guest" if user.slack_id.blank?) ].compact.join(" ") %>
                <%= image_tag user.avatar, alt: "", class: avatar_classes %>
              <% when Hash %>
                <%= image_tag "icons/#{item[:icon][:idle]}.png", alt: "", class: "sidebar__nav-icon sidebar__nav-icon--idle" %>
                <%= image_tag "icons/#{item[:icon][:active]}.png", alt: "", class: "sidebar__nav-icon sidebar__nav-icon--active" %>
              <% else %>
                <%= inline_svg_tag "icons/#{item[:icon]}.svg", class: "sidebar__nav-icon" %>
              <% end %>
            </span>
          <% end %>

          <% label_block = capture do %>
            <span class="sidebar__nav-label"><%= item[:label] %></span>
            <% if item[:notify] %>
              <span class="sidebar__nav-notify-dot" aria-hidden="true"></span>
            <% end %>
          <% end %>

          <% if item[:path] == "#" %>
            <span class="<%= link_classes %> sidebar__nav-link--inert" data-slug="<%= item[:slug] %>" aria-disabled="true">
              <%= icon_block %>
              <%= label_block %>
            </span>
          <% else %>
            <% link_data = { turbo: true, active_prefix: item[:active_prefix], slug: item[:slug] }.compact %>
            <% link_data[:controller] = "notifications-badge" if item[:slug] == "notifications" %>
            <%= link_to item[:path], class: link_classes, aria: (active?(item) ? { current: "page" } : {}), data: link_data do %>
              <%= icon_block %>
              <%= label_block %>
              <% if item.key?(:badge) %>
                <% count = item[:badge].to_i %>
                <span class="sidebar__nav-badge"
                      data-notifications-badge-target="badge"
                      aria-label="<%= count %> unread"
                      <%= "hidden" if count == 0 %>><%= count %></span>
              <% end %>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </nav>

  <div class="sidebar__user" aria-live="polite">
    <% if signed_in? %>
      <div class="sidebar__user-card">
        <div class="sidebar__user-meta">
          <div class="sidebar__user-balance">
            <%= helpers.stardust_icon(extra_class: "sidebar__user-balance-icon") %>
            <span class="sidebar__user-balance-amount"><%= number_with_delimiter(user.cached_balance) %></span>
          </div>
          <%= link_to profile_path(user.display_name), class: "sidebar__user-meta-handle", data: { turbo: true } do %>
            @<%= user.display_name %>
          <% end %>
        </div>

        <div class="sidebar__user-actions">
          <button type="button" class="sidebar__user-settings" onclick="document.getElementById('settings-modal').showModal()" aria-label="Settings">
            <%= inline_svg_tag "icons/gear.svg", class: "sidebar__user-settings-icon" %>
          </button>

          <%= button_to logout_path,
                        method: :delete,
                        class: "sidebar__user-logout",
                        aria: { label: "Logout" },
                        form: { class: "sidebar__user-logout-form", data: { turbo: false } } do %>
            <%= inline_svg_tag "icons/logout.svg", class: "sidebar__user-logout-icon" %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="sidebar__guest-cta">
        <%= link_to "Sign up", root_path, class: "sidebar__guest-cta-btn" %>
      </div>
    <% end %>
  </div>

  <% if signed_in? %>
  <%= render layout: "shared/modal", locals: { id: "settings-modal", title: "Settings" } do %>
    <% preference = user.preference || user.build_preference %>
    <%= form_with url: my_settings_path, method: :patch, local: true, class: "settings-form", id: "settings-form", data: { turbo: false } do |f| %>
      <div class="settings-form__field">
        <label class="settings-form__label" for="hcb_email">HCB Email</label>
        <%= text_field_tag :hcb_email, user.hcb_email, id: "hcb_email", class: "settings-form__input", placeholder: user.email, autocomplete: "email" %>
        <small class="settings-form__hint">Email used for receiving HCB grants. Leave blank to use your default
          email.</small>
      </div>

      <div class="settings-form__field">
        <label class="settings-form__checkbox">
          <%= check_box_tag :leaderboard_optin, "1", preference.leaderboard_optin, id: "leaderboard_optin" %>
          <span>Opt in to the leaderboard</span>
        </label>
        <small class="settings-form__hint">Check this if you want to be shown on the leaderboard</small>
      </div>

      <div class="settings-form__field">
        <p class="settings-form__hint">
          Per-category notification controls (Slack, email) moved to a dedicated page:
          <%= link_to "Manage notifications →", my_notification_settings_path %>
        </p>
      </div>

      <div class="settings-form__field">
        <label class="settings-form__checkbox">
          <%= check_box_tag :search_engine_indexing_off, "1", preference.search_engine_indexing_off, id: "search_engine_indexing_off" %>
          <span>Opt out of search engine indexing</span>
        </label>
        <small class="settings-form__hint">Your profile will not be indexed by search engines</small>
      </div>

      <div class="settings-form__field">
        <label class="settings-form__checkbox">
          <%= check_box_tag :streamer_mode, "1", controller.session[:streamer_mode], id: "streamer_mode" %>
          <span>Streamer mode</span>
        </label>
        <small class="settings-form__hint">Blur sensitive info like addresses and API keys</small>
      </div>

      <div class="settings-form__field">
        <label class="settings-form__label">Hackatime</label>
        <% if user.hackatime_identity.present? %>
          <div class="settings-form__hackatime-status">
            <span class="settings-form__hackatime-linked">Connected</span>
            <button type="submit" form="hackatime-reconnect-form" class="settings-form__hackatime-btn">
              Reconnect
            </button>
          </div>
        <% else %>
          <button type="submit" form="hackatime-reconnect-form" class="settings-form__hackatime-btn">
            Connect Hackatime
          </button>
        <% end %>
        <small class="settings-form__hint">Links your coding time from Hackatime to your projects</small>
      </div>

      <div class="modal__actions">
        <button type="button" class="modal__actions-close" onclick="document.getElementById('settings-form').reset(); document.getElementById('settings-modal').close()">Cancel</button>
        <%= f.submit "Save", class: "modal__actions-close modal__actions-close--primary" %>
      </div>
    <% end %>
    <form id="hackatime-reconnect-form" method="post" action="/auth/hackatime" hidden>
      <input type="hidden" name="origin" value="<%= helpers.request.fullpath %>">
      <input type="hidden" name="authenticity_token" value="<%= helpers.form_authenticity_token %>">
    </form>

  <% end %>
  <% end %>
</aside>
