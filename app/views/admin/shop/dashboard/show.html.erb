<% content_for :title, "Manage Shop" %>
<div>
  <div>
    <h1>Manage Shop</h1>
    <div>
      <%= link_to current_user.shop_manager? && !current_user.admin? ? "New Draft" : "New Product", new_admin_shop_item_path %>
      <% unless current_user.shop_manager? && !current_user.admin? %>
        <%= button_to "Clear Carousel Cache", admin_clear_carousel_cache_path, method: :post, form: { onsubmit: "return confirm('Are you sure you want to clear the carousel cache?')" } %>
      <% end %>
    </div>
  </div>

  <div>
    <h3>Filters & Search</h3>

    <%= form_with url: admin_shop_path, method: :get, local: true do |f| %>
      <div>
        <div>
          <%= f.label :search, "Search" %>
          <%= f.text_field :search, value: params[:search], placeholder: "Name or ID...", autocomplete: "off" %>
        </div>

        <div>
          <%= f.label :type, "Type" %>
          <%= f.select :type, options_for_select(@item_types.map { |t| [t.gsub("ShopItem::", ""), t] }, params[:type]), { include_blank: "All Types" } %>
        </div>

        <div>
          <%= f.label :enabled, "Status" %>
          <%= f.select :enabled, options_for_select([["Enabled", "true"], ["Disabled", "false"]], params[:enabled]), { include_blank: "All" } %>
        </div>

        <div>
          <%= f.label :carousel, "Carousel" %>
          <%= f.select :carousel, options_for_select([["In Carousel", "true"], ["Not in Carousel", "false"]], params[:carousel]), { include_blank: "All" } %>
        </div>
      </div>

      <div>
        <%= f.submit "Apply Filters" %>
        <%= link_to "Clear All", admin_shop_path %>
      </div>
    <% end %>
  </div>

  <div>
    <div>
      <h3>Items</h3>
      <span><%= @shop_items.count %> items</span>
    </div>

    <% if @shop_items.any? %>
       <table>
         <thead>
         <tr>
           <th>ID</th>
           <th></th>
           <th>Name</th>
           <th>Type</th>
           <th>Categories</th>
           <th>Stardust Cost</th>
           <th>USD Cost</th>
           <th>Regions</th>
           <th>Status</th>
           <th>Carousel</th>
           <th>Created</th>
           <th></th>
         </tr>
         </thead>
         <tbody>
         <% @shop_items.each do |item| %>
           <tr>
             <td><code>#<%= item.id %></code></td>
             <td>
               <% if item.image.attached? %>
                 <%= image_tag item.image.variant(:carousel_sm) %>
               <% else %>
                 <div>—</div>
               <% end %>
             </td>
             <td><%= item.name %></td>
             <td><span><%= item.type.to_s.gsub("ShopItem::", "") %></span></td>
             <td>
               <% cats = item.shop_categories %>
               <%= cats.any? ? cats.map(&:title).join(", ") : "—" %>
             </td>
             <td><%= stardust_icon %> <%= item.ticket_cost.to_i %></td>
             <td><%= item.usd_cost ? number_to_currency(item.usd_cost) : "—" %></td>
             <td>
               <%
                 regions = []
                 regions << "🇺🇸" if item.enabled_us
                 regions << "🇪🇺" if item.enabled_eu
                 regions << "🇬🇧" if item.enabled_uk
                 regions << "🇨🇦" if item.enabled_ca
                 regions << "🇦🇺" if item.enabled_au
                 regions << "🇮🇳" if item.enabled_in
                 regions << "🌍" if item.enabled_xx
                 all_regions = item.enabled_us && item.enabled_eu && item.enabled_uk && item.enabled_ca && item.enabled_au && item.enabled_in && item.enabled_xx
               %>
               <% if all_regions %>
                 <span title="All regions">🌐</span>
               <% elsif regions.any? %>
                 <span title="<%= regions.join(" ") %>"><%= regions.join("") %></span>
               <% else %>
                 <span>—</span>
               <% end %>
             </td>
             <td>
               <% if item.draft? %>
                 <span>Draft</span>
               <% elsif item.enabled %>
                 <span>Enabled</span>
               <% else %>
                 <span>Disabled</span>
               <% end %>
             </td>
             <td>
               <% if item.show_in_carousel %>
                 <span>✓</span>
               <% else %>
                 <span>—</span>
               <% end %>
             </td>
             <td><%= item.created_at.strftime("%b %d, %Y") %></td>
             <td>
               <%= link_to "View", admin_shop_item_path(item) %>
             </td>
           </tr>
         <% end %>
         </tbody>
       </table>

       <div>
         <% if @pagy.page > 1 %>
           <%= link_to "← Previous", admin_shop_path(search: params[:search], type: params[:type], enabled: params[:enabled], carousel: params[:carousel], page: @pagy.page - 1) %>
         <% end %>

         <span>Page <%= @pagy.page %> of <%= @pagy.pages %></span>

         <% if @pagy.page < @pagy.pages %>
           <%= link_to "Next →", admin_shop_path(search: params[:search], type: params[:type], enabled: params[:enabled], carousel: params[:carousel], page: @pagy.page + 1) %>
         <% end %>
       </div>
    <% else %>
      <p>No items found matching your filters.</p>
    <% end %>
  </div>

  <div>
    <%= link_to "← Back to Users", admin_users_path %>
  </div>
</div>
