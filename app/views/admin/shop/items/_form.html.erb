</style>

<script>
    (function () {
        const gameConstants = {
            doubloons_per_dollar: <%= Rails.configuration.game_constants.tickets_per_dollar.to_json %>,
            dollars_per_mean_hour: <%= Rails.configuration.game_constants.dollars_per_mean_hour.to_json %>
        };

        const usdCostField = document.getElementById('shop_item_usd_cost');
        const ticketCostField = document.getElementById('shop_item_ticket_cost');
        const hackerScoreField = document.getElementById('shop_item_hacker_score');
        const estimatedTicketsDisplay = document.getElementById('estimated_tickets');
        const averageHoursDisplay = document.getElementById('average_hours_estimated');

        let isTicketCostManuallySet = false;

        if (ticketCostField && ticketCostField.value && parseFloat(ticketCostField.value) !== 0) {
            isTicketCostManuallySet = true;
            ticketCostField.value = Math.round(parseFloat(ticketCostField.value));
        }

        function calculateEstimatedTickets() {
            const usdCost = parseFloat(usdCostField.value) || 0;
            const hackerScore = parseFloat(hackerScoreField.value) || 50;
            const hackerScorePercent = hackerScore / 100;
            const estimatedTickets = gameConstants.doubloons_per_dollar * usdCost * (0.5 + (1 - hackerScorePercent));
            return estimatedTickets;
        }

        function calculateAverageHours() {
            const ticketCost = parseFloat(ticketCostField.value) || 0;
            const averageHours = ticketCost / (gameConstants.doubloons_per_dollar * gameConstants.dollars_per_mean_hour);
            return averageHours;
        }

        function updateCalculations() {
            const estimatedTickets = calculateEstimatedTickets();
            const averageHours = calculateAverageHours();
            if (estimatedTicketsDisplay) {
                estimatedTicketsDisplay.textContent = estimatedTickets > 0 ? Math.round(estimatedTickets) : '—';
            }
            if (averageHoursDisplay) {
                averageHoursDisplay.textContent = averageHours > 0 ? averageHours.toFixed(1) + 'h' : '—';
            }
        }

        function autoFillTicketCost() {
            if (isTicketCostManuallySet) return;

            const estimatedTickets = calculateEstimatedTickets();
            if (usdCostField.value) {
                ticketCostField.value = Math.round(estimatedTickets);
                updateCalculations();
                updateAllRegionalPricing();
            }
        }

        if (usdCostField) {
            usdCostField.addEventListener('input', function () {
                updateCalculations();
                autoFillTicketCost();
            });
        }

        if (ticketCostField) {
            ticketCostField.addEventListener('input', function (e) {
                if (e.isTrusted) {
                    isTicketCostManuallySet = true;
                    if (this.value === '' || parseFloat(this.value) === 0) {
                        isTicketCostManuallySet = false;
                        autoFillTicketCost();
                    }
                }
                updateCalculations();
                updateAllRegionalPricing();
            });
        }

        if (hackerScoreField) {
            hackerScoreField.addEventListener('input', function () {
                updateCalculations();
                autoFillTicketCost();
                updateAllRegionalPricing();
            });
        }

        const limitedCheckbox = document.getElementById('shop_item_limited');
        const stockFieldContainer = document.getElementById('stock_field_container');

        function toggleStockField() {
            if (limitedCheckbox && stockFieldContainer) {
                stockFieldContainer.style.display = limitedCheckbox.checked ? 'block' : 'none';
            }
        }

        if (limitedCheckbox) {
            limitedCheckbox.addEventListener('change', toggleStockField);
            toggleStockField();
        }

        const requiresShipCheckbox = document.getElementById('shop_item_requires_ship');
        const shipRequirementFields = document.getElementById('ship_requirement_fields');

        function toggleShipRequirementFields() {
            if (requiresShipCheckbox && shipRequirementFields) {
                shipRequirementFields.style.display = requiresShipCheckbox.checked ? 'block' : 'none';
            }
        }

        if (requiresShipCheckbox) {
            requiresShipCheckbox.addEventListener('change', toggleShipRequirementFields);
            toggleShipRequirementFields();
        }

        function getHackerMultiplier() {
            const hackerScore = parseFloat(hackerScoreField.value) || 50;
            return 0.5 + (1 - hackerScore / 100);
        }

        // usd_offset is the canonical stored value. All other regional fields derive from it.
        function updateFromUsdOffset(region, skipHours = false) {
            const basePrice = parseFloat(ticketCostField.value) || 0;
            const usdOffsetField = document.querySelector(`[data-region="${region}"].usd-offset`);
            const usdOffset = parseFloat(usdOffsetField.value) || 0;
            const hackerMultiplier = getHackerMultiplier();

            const deltaTickets = usdOffset * gameConstants.doubloons_per_dollar * hackerMultiplier;
            const finalPrice = basePrice + deltaTickets;

            const deltaTicketsDisplay = document.querySelector(`[data-region="${region}"].delta-tickets-display`);
            if (deltaTicketsDisplay) deltaTicketsDisplay.textContent = Math.round(deltaTickets);

            const finalPriceSpan = document.querySelector(`[data-region="${region}"].shop-item-form__final-price`);
            if (finalPriceSpan) finalPriceSpan.textContent = Math.round(finalPrice);

            const estimatedHours = finalPrice / (gameConstants.doubloons_per_dollar * gameConstants.dollars_per_mean_hour);
            const estimatedHoursSpan = document.querySelector(`[data-region="${region}"].estimated-hours`);
            if (estimatedHoursSpan) estimatedHoursSpan.textContent = estimatedHours.toFixed(1);

            if (!skipHours) {
                // delta_hours = usd_offset * hacker_multiplier / dollars_per_mean_hour
                const deltaHours = usdOffset * hackerMultiplier / gameConstants.dollars_per_mean_hour;
                const deltaHoursInput = document.querySelector(`[data-region="${region}"].delta-hours-input`);
                if (deltaHoursInput) deltaHoursInput.value = deltaHours.toFixed(1);
            }
        }

        function updateFromDeltaHours(region) {
            const deltaHoursInput = document.querySelector(`[data-region="${region}"].delta-hours-input`);
            const deltaHours = parseFloat(deltaHoursInput.value) || 0;
            const hackerMultiplier = getHackerMultiplier();
            // usd_offset = delta_hours * dollars_per_mean_hour / hacker_multiplier
            const usdOffset = hackerMultiplier > 0
                ? (deltaHours * gameConstants.dollars_per_mean_hour / hackerMultiplier)
                : 0;
            const usdOffsetField = document.querySelector(`[data-region="${region}"].usd-offset`);
            if (usdOffsetField) usdOffsetField.value = usdOffset.toFixed(2);
            updateFromUsdOffset(region, true);
        }

        function updateAllRegionalPricing() {
            document.querySelectorAll('.usd-offset').forEach(field => {
                updateFromUsdOffset(field.dataset.region);
            });
        }

        document.querySelectorAll('.usd-offset').forEach(field => {
            field.addEventListener('input', function () {
                updateFromUsdOffset(this.dataset.region);
            });
        });

        document.querySelectorAll('.delta-hours-input').forEach(field => {
            field.addEventListener('input', function () {
                updateFromDeltaHours(this.dataset.region);
            });
        });

        updateCalculations();
        autoFillTicketCost();
        updateAllRegionalPricing();

        var aghContentsField = document.getElementById('shop_item_agh_contents');
        if (aghContentsField) {
            aghContentsField.required = (<%= (shop_item.type == "ShopItem::WarehouseItem").to_json %>);
        }
    })();
</script>

<script>
(function() {
    var REGIONS = <%= Shop::Regionalizable::REGIONS.map { |code, cfg| { code: code, name: cfg[:name] } }.to_json.html_safe %>;
    var FLAGS = { US: "🇺🇸", EU: "🇪🇺", UK: "🇬🇧", CA: "🇨🇦", AU: "🇦🇺", IN: "🇮🇳", XX: "🌍" };

    function buildModifierTemplate(index) {
        var regionRows = REGIONS.map(function(r) {
            var code = r.code.toLowerCase();
            return '<tr>' +
                '<td>' + (FLAGS[r.code] || "🏳️") + ' <strong>' + r.code + '</strong></td>' +
                '<td><input type="checkbox" name="shop_item[shop_item_modifiers_attributes][' + index + '][enabled_' + code + ']" value="1"></td>' +
                '<td><input type="number" step="0.01" class="form-control form-control--sm" name="shop_item[shop_item_modifiers_attributes][' + index + '][usd_offset_' + code + ']" placeholder="0.00" style="width:90px;"></td>' +
                '</tr>';
        }).join('');

        return '<div class="modifier-entry" data-modifier-id="new">' +
            '<input type="hidden" name="shop_item[shop_item_modifiers_attributes][' + index + '][id]" value="">' +
            '<input type="hidden" name="shop_item[shop_item_modifiers_attributes][' + index + '][_destroy]" class="modifier-destroy-field" value="0">' +
            '<div class="modifier-entry__header">' +
                '<strong class="modifier-entry__title">New Modifier</strong>' +
                '<button type="button" class="btn-secondary modifier-entry__remove" onclick="removeModifier(this)" style="padding:2px 8px;font-size:0.75rem;">Remove</button>' +
            '</div>' +
            '<div class="shop-item-form__row">' +
                '<div class="shop-item-form__field">' +
                    '<label class="shop-item-form__label">Name</label>' +
                    '<input type="text" name="shop_item[shop_item_modifiers_attributes][' + index + '][name]" class="form-control" placeholder="e.g., Blue, 16GB RAM" required>' +
                '</div>' +
                '<div class="shop-item-form__field">' +
                    '<label class="shop-item-form__label">Group Name (optional)</label>' +
                    '<input type="text" name="shop_item[shop_item_modifiers_attributes][' + index + '][group_name]" class="form-control" placeholder="e.g., Color, Storage">' +
                    '<span class="shop-item-form__hint">Modifiers sharing a group name are mutually exclusive</span>' +
                '</div>' +
            '</div>' +
            '<div class="shop-item-form__row">' +
                '<div class="shop-item-form__field">' +
                    '<label class="shop-item-form__label">&#10022; Stardust Cost</label>' +
                    '<input type="number" min="0" step="1" name="shop_item[shop_item_modifiers_attributes][' + index + '][ticket_cost]" class="form-control" value="0">' +
                    '<span class="shop-item-form__hint">0 = free modifier (e.g., colour choice)</span>' +
                '</div>' +
                '<div class="shop-item-form__field">' +
                    '<label class="shop-item-form__label">USD Cost ($)</label>' +
                    '<input type="number" min="0" step="0.01" name="shop_item[shop_item_modifiers_attributes][' + index + '][usd_cost]" class="form-control" placeholder="0.00">' +
                '</div>' +
            '</div>' +
            '<div class="shop-item-form__row">' +
                '<div class="shop-item-form__field">' +
                    '<label class="shop-item-form__label">Position</label>' +
                    '<input type="number" min="0" step="1" name="shop_item[shop_item_modifiers_attributes][' + index + '][position]" class="form-control" value="0">' +
                '</div>' +
                '<div class="shop-item-form__field" style="display:flex;align-items:center;padding-top:1.5rem;">' +
                    '<label class="shop-item-form__checkbox">' +
                        '<input type="checkbox" name="shop_item[shop_item_modifiers_attributes][' + index + '][enabled]" value="1" checked>' +
                        '<span>Enabled</span>' +
                    '</label>' +
                '</div>' +
            '</div>' +
            '<div class="shop-item-form__field">' +
                '<label class="shop-item-form__label">Image (optional)</label>' +
                '<input type="file" name="shop_item[shop_item_modifiers_attributes][' + index + '][image]" class="form-control">' +
            '</div>' +
            '<details style="margin-top:0.75rem;">' +
                '<summary style="cursor:pointer;font-size:0.875rem;font-weight:500;margin-bottom:0.5rem;">Regional Pricing</summary>' +
                '<div class="shop-item-form__table-wrap" style="margin-top:0.5rem;">' +
                    '<table class="table-data" style="font-size:0.8rem;">' +
                        '<thead><tr><th>Region</th><th>Enabled</th><th>Δ USD Offset</th></tr></thead>' +
                        '<tbody>' + regionRows + '</tbody>' +
                    '</table>' +
                '</div>' +
            '</details>' +
        '</div>';
    }

    window.addModifier = function() {
        var index = new Date().getTime();
        var container = document.getElementById('modifier-entries');
        var div = document.createElement('div');
        div.innerHTML = buildModifierTemplate(index);
        container.appendChild(div.firstChild);
    };

    window.removeModifier = function(btn) {
        var entry = btn.closest('.modifier-entry');
        var destroyField = entry.querySelector('.modifier-destroy-field');
        if (destroyField && destroyField.value !== "0") {
            // already marked, just in case
        } else if (destroyField) {
            destroyField.value = "1";
        }
        entry.style.display = 'none';
    };
})();
</script>

<style>
    .modifier-entry {
        background: var(--color-tan-400);
        border: 1px solid var(--color-brown-500);
        border-radius: 0.5rem;
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .modifier-entry__header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .modifier-entry__title {
        font-size: 0.95rem;
    }
</style>
