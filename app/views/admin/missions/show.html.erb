<% content_for :title, "Admin · #{@mission.name}" %>

<div>
  <header>
    <h1>
      <%= @mission.name %>
      <% if @mission.deleted_at? %>
        <span>Deleted</span>
      <% end %>
    </h1>
    <div>
      <%= link_to "Edit", edit_admin_mission_path(@mission.slug) %>
      <% if @mission.deleted_at? %>
        <%= button_to "Restore", restore_admin_mission_path(@mission.slug), method: :post %>
      <% else %>
        <%= button_to "Soft-delete", admin_mission_path(@mission.slug), method: :delete, data: { turbo_confirm: "Soft-delete this mission?" } %>
      <% end %>
    </div>
  </header>

  <section>
    <h2>Details</h2>
    <dl>
      <dt>Slug</dt>            <dd><code><%= @mission.slug %></code></dd>
      <dt>Enabled</dt>         <dd><%= @mission.enabled? ? "yes" : "no" %></dd>
      <dt>Window</dt>          <dd><%= @mission.start_at&.to_date %> → <%= @mission.end_at&.to_date %></dd>
      <dt>Featured at</dt>     <dd><%= @mission.featured_at %></dd>
      <dt>Achievement name</dt><dd><%= @mission.achievement_name.presence || "—" %></dd>
      <dt>Achievement desc</dt><dd><%= @mission.achievement_description.presence || "—" %></dd>
      <dt>Description</dt>     <dd><%= @mission.description.presence || "—" %></dd>
    </dl>
  </section>

  <section>
    <h2>Steps (<%= @mission.steps.count %>)</h2>
    <ol>
      <% @mission.steps.ordered.each do |step| %>
        <li><%= step.title %></li>
      <% end %>
    </ol>
  </section>

  <section>
    <h2>Prizes (<%= @mission.prizes.count %>)</h2>
    <ul>
      <% @mission.prizes.ordered.includes(:shop_item).each do |prize| %>
        <li><%= prize.shop_item.name %></li>
      <% end %>
    </ul>
  </section>

  <section>
    <h2>Memberships (<%= @mission.memberships.count %>)</h2>
    <ul>
      <% @mission.memberships.includes(:user).each do |m| %>
        <li><%= m.user.display_name %> — <%= m.role.titleize %></li>
      <% end %>
    </ul>
  </section>

  <section>
    <h2>Shop unlocks (<%= @mission.shop_unlocks.count %>)</h2>
    <ul>
      <% @mission.shop_unlocks.includes(:shop_item).each do |u| %>
        <li><%= u.shop_item.name %></li>
      <% end %>
    </ul>
  </section>

  <section>
    <h2>Recent submissions</h2>
    <ul>
      <% @submissions.each do |s| %>
        <li>
          <%= link_to "##{s.id} (#{s.status})", mission_submission_path(s) %>
          — <%= s.ship_event&.post&.user&.display_name %>
          <%= time_ago_in_words(s.created_at) %> ago
        </li>
      <% end %>
    </ul>
  </section>

  <section>
    <h2>Audit log</h2>
    <table>
      <thead>
        <tr><th>When</th><th>Whodunnit</th><th>Item</th><th>Event</th></tr>
      </thead>
      <tbody>
        <% @versions.each do |v| %>
          <tr>
            <td><%= v.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td><%= v.whodunnit %></td>
            <td><%= v.item_type %>##<%= v.item_id %></td>
            <td><%= v.event %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>
