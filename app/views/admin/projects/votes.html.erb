<% content_for :title, "Votes on #{@project.title}" %>
<h1 align="center">Votes on <%= @project.title %> (#<%= @project.id %>)</h1>

<div>
  <%= link_to "← Back to Project", admin_project_path(@project) %>
  <label>
    <input type="checkbox" id="toggle-reasons" checked>
    Show vote reasons
  </label>
</div>

<div>
  <% if @votes.any? %>
    <table>
      <thead>
        <tr>
          <th>Time</th>
          <th>Voter</th>
          <th>Orig.</th>
          <th>Tech.</th>
          <th>Usab.</th>
          <th>Story.</th>
          <th>Time</th>
          <th>Demo</th>
          <th>Repo</th>
          <th>Discarded</th>
          <th>Reason</th>
        </tr>
      </thead>
      <tbody>
        <% @votes.each do |vote| %>
          <tr>
            <td><%= time_ago_in_words(vote.created_at) %> ago</td>
            <td>
              <% if vote.user %>
                <%= link_to vote.user.display_name || "User ##{vote.user.id}", admin_user_path(vote.user) %>
              <% else %>
                <span>Unknown</span>
              <% end %>
            </td>
            <td><%= vote.originality_score || "—" %></td>
            <td><%= vote.technical_score || "—" %></td>
            <td><%= vote.usability_score || "—" %></td>
            <td><%= vote.storytelling_score || "—" %></td>
            <td><%= vote.time_taken_to_vote ? "#{vote.time_taken_to_vote}s" : "—" %></td>
            <td><%= vote.demo_url_clicked ? "✓" : "—" %></td>
            <td><%= vote.repo_url_clicked ? "✓" : "—" %></td>
            <td>
              <% if vote.suspicious %>
                <span>⚠ Yes</span>
              <% else %>
                <span>No</span>
              <% end %>
            </td>
            <td>
              <% if vote.reason.present? %>
                <details>
                  <summary>View</summary>
                  <div><%= vote.reason %></div>
                </details>
              <% else %>
                <span>—</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @pagy.pages > 1 %>
      <div>
        <%== @pagy.series_nav %>
      </div>
    <% end %>
  <% else %>
    <p>No votes received yet.</p>
  <% end %>
</div>

<script>
  (function() {
    const toggle = document.getElementById("toggle-reasons");
    if (!toggle) return;

    const setReasonsExpanded = (expanded) => {
      document.querySelectorAll("td.vote-reasons details").forEach((details) => {
        details.open = expanded;
      });
    };

    setReasonsExpanded(toggle.checked);
    toggle.addEventListener("change", function() {
      setReasonsExpanded(this.checked);
    });
  })();
</script>
