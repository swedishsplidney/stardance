<% content_for :title, "Project Search" %>
<h1>Project Search</h1>

<% if policy(:super_star_dashboard).show? %>
  <p><%= link_to "→ Super Stars", admin_super_stars_path %></p>
<% end %>

<div>
  <%= link_to "Active", admin_projects_path(filter: "active", query: params[:query]) %>
  <%= link_to "Deleted", admin_projects_path(filter: "deleted", query: params[:query]) %>
  <%= link_to "All", admin_projects_path(filter: "all", query: params[:query]) %>
</div>

<%= form_with url: admin_projects_path, method: :get, local: true do %>
  <%= hidden_field_tag :filter, @filter %>
  <%= text_field_tag :query, params[:query],
    placeholder: "Search projects by title or other meta info...",
    autocomplete: "off" %>

  <%= submit_tag "Search" %>
<% end %>

<% if @projects.any? %>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Description</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @projects.each do |project| %>
        <tr>
          <td><%= project.id %></td>
          <td><%= project.title %></td>
          <td><%= truncate(project.description, length: 60) %></td>
          <td>
            <% if project.deleted? %>
              <span>Deleted</span>
            <% else %>
              <span>Active</span>
            <% end %>
          </td>
          <td>
            <%= link_to "View", admin_project_path(project) %>
            <% if project.deleted? %>
              <%= button_to "Restore", restore_admin_project_path(project), method: :post %>
            <% else %>
              <%= button_to "Delete", delete_admin_project_path(project), method: :post, data: { confirm: "Are you sure you want to delete this project?" } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No projects found.</p>
<% end %>

<% if @pagy.pages > 1 %>
  <div>
    <%== @pagy.series_nav %>
  </div>
<% end %>

<%= link_to "Go back", admin_users_path %>
