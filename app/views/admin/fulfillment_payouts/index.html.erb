<% content_for :title, "Fulfillment Payouts" %>
<h1>Fulfillment Payouts</h1>

<div>
  <%= button_to "Trigger Manual Run", trigger_admin_fulfillment_payouts_path, method: :post, data: { confirm: "This will calculate payouts only for orders fulfilled since the last run. Continue?" } %>
</div>

<% if @runs.any? %>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Status</th>
        <th>Period</th>
        <th>Orders</th>
        <th>Total Tickets</th>
        <th>Created</th>
        <th>Approved By</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @runs.each do |run| %>
        <tr>
          <td><%= link_to "##{run.id}", admin_fulfillment_payout_path(run) %></td>
          <td>
            <% case run.aasm_state %>
            <% when "pending_approval" %>
              <span>Pending Approval</span>
            <% when "approved" %>
              <span>Approved</span>
            <% when "rejected" %>
              <span>Rejected</span>
            <% end %>
          </td>
          <td>
            <%= run.period_start&.strftime("%b %d, %Y") || "All time" %>
            &rarr;
            <%= run.period_end.strftime("%b %d, %Y") %>
          </td>
          <td><%= run.total_orders %></td>
          <td><%= number_with_delimiter(run.total_amount) %> <%= stardust_icon %></td>
          <td><%= run.created_at.strftime("%b %d, %Y %H:%M") %></td>
          <td><%= run.approved_by_user&.display_name || "-" %></td>
          <td><%= link_to "View", admin_fulfillment_payout_path(run) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No payout runs yet. The first run is scheduled for Friday at noon (Europe/London).</p>
<% end %>

<%= link_to "Go back", admin_users_path %>
