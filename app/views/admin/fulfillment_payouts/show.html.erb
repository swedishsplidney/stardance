<% content_for :title, "Fulfillment Payout Run ##{@run.id}" %>
<h1>Fulfillment Payout Run #<%= @run.id %></h1>

<div>
  <div>
    <h3>Status</h3>
    <p>
      <% case @run.aasm_state %>
      <% when "pending_approval" %>
        <span>Pending Approval</span>
      <% when "approved" %>
        <span>Approved</span>
      <% when "rejected" %>
        <span>Rejected</span>
      <% end %>
    </p>
  </div>

  <div>
    <h3>Period</h3>
    <p><%= @run.period_start&.strftime("%b %d, %Y %H:%M") || "All time" %> &rarr; <%= @run.period_end.strftime("%b %d, %Y %H:%M") %></p>
  </div>

  <div>
    <h3>Totals</h3>
    <table>
      <tr><td>Orders</td><td><%= @run.total_orders %></td></tr>
      <tr><td>Tickets</td><td><%= number_with_delimiter(@run.total_amount) %> <%= stardust_icon %></td></tr>
      <tr><td>Fulfillers</td><td><%= @run.lines.count %></td></tr>
    </table>
  </div>
</div>

<% if @run.pending_approval? %>
  <div>
    <%= button_to "Approve & Distribute", approve_admin_fulfillment_payout_path(@run), method: :post, data: { confirm: "This will distribute #{number_with_delimiter(@run.total_amount)} tickets to #{@run.lines.count} fulfillers. This cannot be undone. Continue?" } %>
    <%= button_to "Reject", reject_admin_fulfillment_payout_path(@run), method: :post, data: { confirm: "This will reject this payout run and release the orders for the next run. Continue?" } %>
  </div>
<% end %>

<% if @run.approved? && @run.approved_by_user %>
  <p>Approved by <%= link_to @run.approved_by_user.display_name, admin_user_path(@run.approved_by_user) %> on <%= @run.approved_at&.strftime("%b %d, %Y %H:%M") %></p>
<% end %>

<h2>Payout Lines</h2>
<table>
  <thead>
    <tr>
      <th>Fulfiller</th>
      <th>Orders Fulfilled</th>
      <th>Tickets Earned</th>
    </tr>
  </thead>
  <tbody>
    <% @run.lines.includes(:user).order(amount: :desc).each do |line| %>
      <tr>
        <td><%= link_to line.user.display_name, admin_user_path(line.user) %></td>
        <td><%= line.order_count %></td>
        <td><%= number_with_delimiter(line.amount) %> <%= stardust_icon %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "Back to Payouts", admin_fulfillment_payouts_path %>
