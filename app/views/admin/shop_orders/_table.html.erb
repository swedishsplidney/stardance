<% if orders.any? %>
  <div>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>User</th>
          <th>Item</th>
          <th>Qty</th>
          <th>Tickets</th>
          <th>Status</th>
          <% if @view == 'fulfillment' %>
            <th>Region</th>
          <% end %>
          <% if (current_user.admin? || current_user.fulfillment_person?) && @view == 'fulfillment' %>
            <th>Assignee</th>
          <% end %>
          <th><%= @view == 'fulfillment' ? 'Hang Time' : 'Created' %></th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% orders.each do |order| %>
          <% can_see = order.can_view_address?(current_user) %>
          <tr>
            <td>#<%= order.id %></td>
            <td>
              <%= link_to order.user.display_name || "Unknown", admin_user_path(order.user) %><br>
              <small><%= order.user.email %></small>
            </td>
            <td>
              <%= order.shop_item.name %><br>
              <small><%= order.shop_item.type&.demodulize %></small>
              <% if order.parent_order_id.present? %>
                <br><small>🔗 Accessory for #<%= order.parent_order_id %></small>
              <% elsif order.accessory_orders.any? %>
                <br><small>🎁 +<%= order.accessory_orders.count %> accessories</small>
              <% end %>
            </td>
            <td>
              <span>
                <%= order.quantity %>
              </span>
              <% if order.quantity > 1 %>
                <br><span>+1</span>
              <% end %>
            </td>
            <td><%= order.total_cost %></td>
            <td>
              <span>
                <%= order.aasm_state.humanize %>
              </span>
              <% if order.aasm_state == "fulfilled" %>
                <br><small>Shipped to user</small>
              <% end %>
            </td>

            <% if @view == 'fulfillment' %>
              <td>
                <% if order.frozen_address.present? %>
                  <span>
                    <%= country_name_from_code(order.frozen_address["country"]) %>
                  </span>
                <% else %>
                  <span>—</span>
                <% end %>
              </td>
            <% end %>

            <% if (current_user.admin? || current_user.fulfillment_person?) && @view == 'fulfillment' %>
              <td>
                <% if order.assigned_to_user.present? %>
                  <div>
                    <%= image_tag order.assigned_to_user.avatar, alt: order.assigned_to_user.display_name, style: "width: 24px; height: 24px; border-radius: 50%; object-fit: cover;" %>
                    <span><%= order.assigned_to_user.display_name %></span>
                  </div>
                <% end %>
                <div data-controller="searchable-select">
                  <%= form_with url: assign_user_admin_shop_order_path(order), method: :post, local: true, data: { turbo: false } do |f| %>
                    <%= f.hidden_field :assigned_to_user_id, value: order.assigned_to_user_id, data: { searchable_select_target: "hiddenField" } %>
                    <input
                      type="text"
                      placeholder="<%= order.assigned_to_user.present? ? 'Change...' : 'Assign...' %>"
                      data-searchable-select-target="input"
                      data-action="focus->searchable-select#open input->searchable-select#filter"
                      autocomplete="off">
                    <div data-searchable-select-target="dropdown">
                      <div
                        data-searchable-select-target="option"
                        data-action="click->searchable-select#selectAndSubmit"
                        data-value=""
                        data-label=""
                        data-search-text="unassigned none">
                        <span>Unassign</span>
                      </div>
                      <% @fulfillment_users.each do |user| %>
                        <div
                          data-searchable-select-target="option"
                          data-action="click->searchable-select#selectAndSubmit"
                          data-value="<%= user.id %>"
                          data-label="<%= user.display_name %>"
                          data-search-text="<%= "#{user.display_name} #{user.regions.join(' ')} #{user.id}".downcase %>">
                          <img src="<%= user.avatar %>" alt="">
                          <span><%= user.display_name %></span>
                          <% if user.has_regions? %>
                            <span><%= user.regions.join(", ") %></span>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </td>
            <% end %>

            <td>
              <% if @view == 'fulfillment' && order.awaiting_periodical_fulfillment_at %>
                <span>
                  <%= time_ago_in_words(order.awaiting_periodical_fulfillment_at) %>
                </span>
                <br><small>since approval</small>
              <% elsif @view == 'fulfillment' %>
                <span>not approved yet</span>
              <% else %>
                <%= order.created_at.strftime("%b %d, %Y") %><br>
                <small><%= order.created_at.strftime("%l:%M %p") %></small>
              <% end %>
            </td>
            <td>
              <%= link_to "Inspect", admin_shop_order_path(order, return_view: params[:view], return_status: params[:status]) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div>
    <p>No orders found matching the filters.</p>
  </div>
<% end %>
