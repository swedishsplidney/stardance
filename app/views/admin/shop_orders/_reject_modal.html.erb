<% is_fraud_dept = current_user.fraud_dept? && params[:return_view] != "fulfillment" %>
<dialog id="reject-modal">
  <h2>Reject Order #<%= order.id %></h2>

  <%= form_with url: reject_admin_shop_order_path(order), method: :post, local: true do |f| %>
    <%= hidden_field_tag :return_view, params[:return_view] if params[:return_view].present? %>
    <%= hidden_field_tag :return_status, params[:return_status] if params[:return_status].present? %>

    <div>
      <%= f.label :reason, "Rejection Reason (shown to user)" %>
      <%= f.text_area :reason, placeholder: "Enter reason for rejection...", rows: 3 %>
    </div>

    <% if is_fraud_dept %>
      <div>
        <%= f.label :internal_rejection_reason, "Internal Reason (required, staff only)" %>
        <%= f.text_area :internal_rejection_reason, placeholder: "Detailed internal reason for this rejection...", rows: 3, required: true %>
      </div>

      <div>
        <%= f.label :fraud_related_project_id, "Related Project ID (required)" %>
        <%= f.number_field :fraud_related_project_id, placeholder: "e.g. 1234", required: true %>
      </div>

      <div>
        <%= f.label :joe_case_url, "Joe Case URL (optional)" %>
        <%= f.url_field :joe_case_url, placeholder: "https://..." %>
      </div>
    <% end %>

    <div>
      <button type="button" onclick="document.getElementById('reject-modal').close()">Cancel</button>
      <%= f.submit "Reject Order" %>
    </div>
  <% end %>
</dialog>
