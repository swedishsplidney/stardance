<% content_for :title, "Project Reports" %>
<h1>🚩 Project Reports</h1>

<div>
  <div>
    <span>⏳</span>
    <div>
      <span><%= @counts[:pending] %></span>
      <span>Pending</span>
    </div>
  </div>
  <div>
    <span>✅</span>
    <div>
      <span><%= @counts[:reviewed] %></span>
      <span>Reviewed</span>
    </div>
  </div>
  <div>
    <span>🗑️</span>
    <div>
      <span><%= @counts[:dismissed] %></span>
      <span>Dismissed</span>
    </div>
  </div>
  <div>
    <%= button_to "⚡ Process Demo Broken", process_demo_broken_admin_reports_path, method: :post, data: { confirm: "This will auto-review projects with 5+ pending demo_broken reports and re-certify them. Continue?" } %>
  </div>
</div>

<div>
  <div>
    <h3>Filters</h3>

    <%= form_with url: admin_reports_path, method: :get, local: true do |f| %>
      <div>
        <div>
          <%= f.label :status, "Status" %>
          <%= f.select :status, options_for_select([["Pending", "pending"], ["Reviewed", "reviewed"], ["Dismissed", "dismissed"]], params[:status]), { include_blank: "All" } %>
        </div>

        <div>
          <%= f.label :reason, "Reason" %>
          <%= f.select :reason, options_for_select(Project::Report::REASONS.map { |r| [r.titleize, r] }, params[:reason]), { include_blank: "All" } %>
        </div>

        <div>
          <%= f.submit "Apply" %>
          <%= link_to "Clear", admin_reports_path %>
        </div>
      </div>
    <% end %>
  </div>

  <%= render partial: "action_leaderboard", locals: { time_range: @time_range, limit: @limit } %>
</div>

<div>
  <% if @reports.any? %>
    <table>
      <thead>
        <tr>
          <th>Report</th>
          <th>Project</th>
          <th>Reporter</th>
          <th>Reason</th>
          <th>Status</th>
          <th>Actioned By</th>
          <th>Age</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @reports.each do |report| %>
          <tr>
            <td><code>#<%= report.id %></code></td>
            <td>
              <% if report.project %>
                <%= link_to report.project.title, admin_project_path(report.project) %>
              <% else %>
                <span>(Deleted)</span>
              <% end %>
            </td>
            <td>
              <div>
                <img src="<%= report.reporter.avatar %>" alt="">
                <%= link_to report.reporter.display_name, admin_user_path(report.reporter) %>
              </div>
            </td>
            <td>
              <span>
                <%= report.reason.titleize %>
              </span>
            </td>
            <td>
              <span>
                <%= report.status %>
              </span>
            </td>
            <td>
              <% reviewer_info = @reviewers_by_report[report.id] %>
              <% if reviewer_info.is_a?(User) %>
                <div>
                  <img src="<%= reviewer_info.avatar %>" alt="">
                  <span><%= reviewer_info.display_name %></span>
                </div>
              <% elsif reviewer_info == :auto %>
                <span>🤖 Auto</span>
              <% else %>
                <span>—</span>
              <% end %>
            </td>
            <td>
              <span title="<%= report.created_at.strftime('%Y-%m-%d %H:%M') %>">
                <%= time_ago_in_words(report.created_at) %> ago
              </span>
            </td>
            <td>
              <div>
                <%= link_to "View", admin_report_path(report) %>
                <% if report.pending? %>
                  <%= button_to "✓", review_admin_report_path(report), method: :post, title: "Mark reviewed" %>
                  <%= button_to "✗", dismiss_admin_report_path(report), method: :post, title: "Dismiss" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No reports found matching your filters.</p>
  <% end %>
</div>

<div>
  <%= link_to "← Back to Users", admin_users_path %>
</div>
