<% content_for :title, "Report ##{@report.id}" %>
<h1>🚩 Report #<%= @report.id %></h1>

<div>
  <div>
    <h3>Report Info</h3>
    <div>
      <div>
        <span>Status</span>
        <span><%= @report.status %></span>
      </div>
      <div>
        <span>Reason</span>
        <span><%= @report.reason.titleize %></span>
      </div>
      <div>
        <span>Reporter</span>
        <div>
          <img src="<%= @report.reporter.avatar %>" alt="">
          <%= link_to @report.reporter.display_name, admin_user_path(@report.reporter) %>
        </div>
      </div>
      <div>
        <span>Created</span>
        <span><%= @report.created_at.strftime("%b %d, %Y at %H:%M") %> (<%= time_ago_in_words(@report.created_at) %> ago)</span>
      </div>
    </div>

    <div>
      <strong>Details:</strong>
      <p><%= @report.details %></p>
    </div>

    <% if @report.pending? %>
      <div>
        <%= button_to "✅ Mark as Reviewed", review_admin_report_path(@report), method: :post %>
        <%= button_to "🗑️ Dismiss Report", dismiss_admin_report_path(@report), method: :post %>
      </div>
    <% elsif @report.reviewed? %>
      <div>
        ✅ This report has been reviewed
      </div>
    <% elsif @report.dismissed? %>
      <div>
        🗑️ This report has been dismissed
      </div>
    <% end %>
  </div>

  <div>
    <h3>Reported Project</h3>
    <% if @report.project.present? %>
      <div>
        <div>
          <span>Title</span>
          <strong><%= @report.project.title %></strong>
        </div>
        <div>
          <span>Owner</span>
          <% owner = @report.project.memberships.find_by(role: :owner)&.user %>
          <% if owner %>
            <div>
              <img src="<%= owner.avatar %>" alt="">
              <%= link_to owner.display_name, admin_user_path(owner) %>
            </div>
          <% else %>
            <span>Unknown</span>
          <% end %>
        </div>
        <div>
          <span>Demo URL</span>
          <% if @report.project.demo_url.present? %>
            <%= link_to truncate(@report.project.demo_url, length: 50), @report.project.demo_url, target: "_blank" %>
          <% else %>
            <span>Not provided</span>
          <% end %>
        </div>
        <div>
          <span>Repo URL</span>
          <% if @report.project.repo_url.present? %>
            <%= link_to truncate(@report.project.repo_url, length: 50), @report.project.repo_url, target: "_blank" %>
          <% else %>
            <span>Not provided</span>
          <% end %>
        </div>
        <div>
          <span>Members</span>
          <span><%= @report.project.users.map(&:display_name).join(", ") %></span>
        </div>
      </div>

      <% if @report.project.description.present? %>
        <div>
          <strong>Description:</strong>
          <p><%= @report.project.description %></p>
        </div>
      <% end %>

      <div>
        <%= link_to "View Project →", admin_project_path(@report.project) %>
        <% reported_user = @report.project.memberships.find_by(role: :owner)&.user %>
        <% if reported_user %>
          <%= link_to "View Owner →", admin_user_path(reported_user) %>
        <% end %>
      </div>
    <% else %>
      <div>
        This project has been deleted.
      </div>
    <% end %>
  </div>
</div>

<%= render "admin/shared/audit_log", record: @report, item_type: "Project::Report" %>

<div>
  <%= link_to "← Back to Reports", admin_reports_path %>
</div>
