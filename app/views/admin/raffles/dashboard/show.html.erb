<% content_for :title, "Raffle admin" %>
<%= render "admin/raffles/shared/nav" %>

<h1>Raffle, overview</h1>

<div class="flex">
  <div class="card">
    <h3>Current week</h3>
    <% if @current_week %>
      <p>Week <strong><%= @current_week.number %></strong> of 16 · <%= @current_week.prize %></p>
      <% if @current_week.drawn? %>
        <p>Winner: <strong><%= link_to @current_week.winner_participant.display_name, admin_raffles_participant_path(@current_week.winner_participant) %></strong></p>
      <% end %>
    <% else %>
      <p>None active</p>
    <% end %>
  </div>
  <div class="card">
    <h3>Participants</h3>
    <p style="font-size: 2rem; font-weight: 700; margin: 0"><%= @participant_count %></p>
  </div>
  <div class="card">
    <h3>Referrals</h3>
    <p><strong><%= @verified_count %></strong> verified · <strong><%= @pending_count %></strong> pending</p>
  </div>
</div>

<% if @current_week %>
  <p>
    <% unless @current_week.drawn? %>
      <%= button_to "Draw winner for week #{@current_week.number}",
                    draw_admin_raffles_week_path(@current_week), method: :post,
                    class: "btn-primary slim",
                    data: { turbo_confirm: "Draw a winner for week #{@current_week.number}?" } %>
    <% end %>
    <%= button_to "Close week #{@current_week.number} & open next",
                  close_admin_raffles_week_path(@current_week), method: :post,
                  class: "btn-secondary slim",
                  data: { turbo_confirm: "Archive week #{@current_week.number} and open the next week?" } %>
  </p>
<% end %>

<div class="admin-section">
  <h3 class="admin-section__header">Leaderboard, this week</h3>
  <% if @leaderboard.any? %>
    <table class="table-data">
      <thead><tr><th>#</th><th>Participant</th><th>Code</th><th>Entries</th></tr></thead>
      <tbody>
        <% @leaderboard.each_with_index do |(participant, entries), i| %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= link_to participant.display_name, admin_raffles_participant_path(participant) %></td>
            <td><code><%= participant.code %></code></td>
            <td><%= entries %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No entries this week yet.</p>
  <% end %>
</div>
