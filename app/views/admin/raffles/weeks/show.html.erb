<% content_for :title, "Week #{@week.number}" %>
<%= render "admin/raffles/shared/nav" %>

<h1>Week <%= @week.number %> <small>(<%= @week.status %>)</small></h1>

<ul>
  <li>Prize: <%= @week.prize %></li>
  <li>Opened: <%= @week.opened_at&.to_date || "—" %> · Closed: <%= @week.closed_at&.to_date || "—" %></li>
  <% if @week.drawn? %>
    <li>Winner: <%= link_to @week.winner_participant.display_name, admin_raffles_participant_path(@week.winner_participant) %> (drawn <%= @week.drawn_at.to_date %>)</li>
  <% end %>
</ul>

<% if @week.status_active? %>
  <p>
    <% unless @week.drawn? %>
      <%= button_to "Draw winner", draw_admin_raffles_week_path(@week), method: :post,
                    data: { turbo_confirm: "Draw a winner for week #{@week.number}? This cannot be undone." } %>
    <% end %>
    <%= button_to "Close & open next", close_admin_raffles_week_path(@week), method: :post,
                  data: { turbo_confirm: "Archive week #{@week.number} and open the next?" } %>
  </p>
<% end %>

<h2>Standings</h2>
<% if @standings.any? %>
  <table>
    <thead><tr><th>#</th><th>Participant</th><th>Entries</th></tr></thead>
    <tbody>
      <% @standings.each_with_index do |(participant, entries), i| %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= link_to participant.display_name, admin_raffles_participant_path(participant) %></td>
          <td><%= entries %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No entries credited to this week.</p>
<% end %>
