<% content_for :title, "YSWS Review Queue" %>

<main class="ysws-queue" role="main">
  <h1>YSWS Review Queue</h1>

  <% if @reviews.any? %>
    <div class="ysws-queue__summary" role="status" aria-live="polite">
      <span class="ysws-queue__summary-label">Pending reviews</span>
      <span class="ysws-queue__summary-count"><%= @reviews.count %></span>
    </div>

    <div class="ysws-queue__table-container">
      <table>
        <thead>
          <tr>
            <th>Review ID</th>
            <th>Project Type</th>
            <th>Project Name</th>
            <th>User</th>
            <th>Length (hours)</th>
            <th>Age</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @reviews.each do |review| %>
            <tr>
              <td data-label="ID">#<%= review.id %></td>
              <td data-label="Type">
                <%= review.project&.project_type.presence || tag.span("—", style: "opacity: 0.5;") %>
              </td>
              <td data-label="Project">
                <% if review.project %>
                  <%= link_to review.project.title, admin_project_path(review.project) %>
                <% else %>
                  <span class="ysws-queue__placeholder">—</span>
                <% end %>
              </td>
              <td data-label="User">
                <%= link_to review.user.display_name || "Unknown", admin_user_path(review.user) %>
                <span class="ysws-queue__cell-note"><%= review.user.email %></span>
              </td>
              <td data-label="Hours">
                <% hours = review.original_minutes ? (review.original_minutes / 60.0).round(1) : 0 %>
                <%= hours %> hrs
              </td>
              <td data-label="Age">
                <% age_in_days = ((Time.current - review.created_at) / 1.day).floor %>
                <% if age_in_days == 0 %>
                  <span class="ysws-queue__age ysws-queue__age--today">Today</span>
                <% elsif age_in_days < 7 %>
                  <span class="ysws-queue__age ysws-queue__age--recent"><%= pluralize(age_in_days, "day") %> ago</span>
                <% else %>
                  <span class="ysws-queue__age ysws-queue__age--old"><%= pluralize(age_in_days, "day") %> ago</span>
                <% end %>
              </td>
              <td data-label="Actions">
                <%= link_to "View", admin_certification_ysws_review_path(review), class: "ysws-queue__view-btn" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="ysws-queue__empty" role="status">
      <p>No pending reviews. Great job!</p>
    </div>
  <% end %>
</main>
