<% content_for :title, "Audit Logs" %>
<div>
  <div>
    <h1>Audit Logs</h1>
    <% if @affected_record.present? %>
      <div>
        Showing logs for <strong><%= params[:item_type] %> #<%= params[:item_id] %></strong>
        <% if @affected_record.respond_to?(:display_name) %>
          (<%= @affected_record.display_name %>)
        <% elsif @affected_record.respond_to?(:name) %>
          (<%= @affected_record.name %>)
        <% elsif @affected_record.respond_to?(:title) %>
          (<%= @affected_record.title %>)
        <% end %>
        <%= link_to "× Clear filter", admin_audit_logs_path %>
      </div>
    <% end %>
  </div>

  <div>
    <h3>Filters & Search</h3>

    <%= form_with url: admin_audit_logs_path, method: :get, local: true do |f| %>
      <div>
        <div>
          <%= f.label :search, "Search Changes" %>
          <%= f.text_field :search, value: params[:search], placeholder: "Search in changes..." %>
        </div>

        <div>
          <%= f.label :item_type, "Model Type" %>
          <%= f.select :item_type, options_for_select(@item_types, params[:item_type]), { include_blank: "All" } %>
        </div>

        <div>
          <%= f.label :item_id, "Record ID" %>
          <%= f.number_field :item_id, value: params[:item_id], placeholder: "e.g. 123" %>
        </div>

        <div>
          <%= f.label :event, "Action" %>
          <%= f.select :event, options_for_select(@events, params[:event]), { include_blank: "All" } %>
        </div>

        <div data-controller="searchable-select">
          <%= f.label :whodunnit, "Performed By" %>
          <% selected_user = @users.find { |u| u.id.to_s == params[:whodunnit].to_s } %>
          <%= f.hidden_field :whodunnit, value: params[:whodunnit], data: { searchable_select_target: "hiddenField" } %>
          <input
            type="text"
            placeholder="Search users..."
            value="<%= selected_user&.display_name %>"
            data-searchable-select-target="input"
            data-action="focus->searchable-select#open input->searchable-select#filter"
            autocomplete="off">
          <div data-searchable-select-target="dropdown">
            <div
              data-searchable-select-target="option"
              data-action="click->searchable-select#clear"
              data-value=""
              data-label=""
              data-search-text="all">All</div>
            <% @users.each do |user| %>
              <div
                data-searchable-select-target="option"
                data-action="click->searchable-select#select"
                data-value="<%= user.id %>"
                data-label="<%= user.display_name %>"
                data-search-text="<%= "#{user.display_name} #{user.id}".downcase %>">
                <img src="<%= user.avatar %>" alt="">
                <span><%= user.display_name %></span>
                <span>#<%= user.id %></span>
              </div>
            <% end %>
          </div>
        </div>

        <div>
          <%= f.label :start_date, "From" %>
          <%= f.date_field :start_date, value: params[:start_date] %>
        </div>

        <div>
          <%= f.label :end_date, "To" %>
          <%= f.date_field :end_date, value: params[:end_date] %>
        </div>
      </div>

      <div>
        <%= f.check_box :show_system, { checked: @show_system }, "1", "0" %>
        <%= f.label :show_system, "Show system activities" %>
      </div>

      <div>
        <%= f.submit "Apply Filters" %>
        <%= link_to "Clear All", admin_audit_logs_path %>
      </div>
    <% end %>
  </div>

  <div>
    <% if @versions.any? %>
      <table>
        <thead>
          <tr>
            <th>Timestamp</th>
            <th>User</th>
            <th>Action</th>
            <th>Model</th>
            <th>Record</th>
            <th>Changes</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% deduped_versions = dedupe_versions(@versions.to_a) %>
          <% users_by_id = User.where(id: deduped_versions.map(&:whodunnit).compact.uniq).index_by { |u| u.id.to_s } %>
          <% deduped_versions.each do |version| %>
            <tr>
              <td>
                <span><%= version.created_at.strftime("%b %d, %Y") %></span>
                <span><%= version.created_at.strftime("%H:%M:%S") %></span>
              </td>
              <td>
                <% if version.whodunnit.present? %>
                  <% user = users_by_id[version.whodunnit.to_s] %>
                  <% if user %>
                    <div>
                      <img src="<%= user.avatar %>" alt="">
                      <span><%= user.display_name %></span>
                    </div>
                  <% else %>
                    <span>User #<%= version.whodunnit %></span>
                  <% end %>
                <% else %>
                  <span>System</span>
                <% end %>
              </td>
              <td>
                <% display = audit_event_display(version) %>
                <span>
                  <%= display[:label] %>
                </span>
              </td>
              <td><code><%= version.item_type %></code></td>
              <td>
                <% case version.item_type
                   when "User" %>
                  <%= link_to "##{version.item_id}", admin_user_path(version.item_id) %>
                <% when "Project" %>
                  <%= link_to "##{version.item_id}", admin_project_path(version.item_id) %>
                <% when "ShopOrder" %>
                  <%= link_to "##{version.item_id}", admin_shop_order_path(version.item_id) %>
                <% when "ShopItem" %>
                  <%= link_to "##{version.item_id}", admin_shop_item_path(version.item_id) %>
                <% else %>
                  <code>#<%= version.item_id %></code>
                <% end %>
              </td>
              <td>
                <% if version.object_changes.present? %>
                  <%
                    raw_changes = version.object_changes
                    changes = if raw_changes.is_a?(Hash)
                      raw_changes
                    elsif raw_changes.is_a?(String)
                      YAML.safe_load(raw_changes, permitted_classes: [Time, Date, DateTime, BigDecimal, Symbol]) rescue {}
                    else
                      {}
                    end
                  %>
                  <% sensitive_fields = %w[encrypted_password password_digest frozen_address frozen_address_ciphertext frozen_phone_ciphertext email address ip_address phone phone_number hcb_email] %>
                  <div>
                    <% changes.keys.take(3).each do |k| %>
                      <% v = changes[k] %>
                      <div>
                        <code><%= k %></code>
                        <% if sensitive_fields.include?(k.to_s) %>
                          <span>🔒 [REDACTED]</span>
                        <% elsif v.is_a?(Array) && v.length == 2 %>
                          <span><%= truncate(v[0].to_s, length: 30) %></span>
                          → <span><%= truncate(v[1].to_s, length: 30) %></span>
                        <% else %>
                          <span><%= truncate(v.to_s, length: 50) %></span>
                        <% end %>
                      </div>
                    <% end %>
                    <% if changes.keys.count > 3 %>
                      <span>(+<%= changes.keys.count - 3 %> more)</span>
                    <% end %>
                  </div>
                <% else %>
                  <span>—</span>
                <% end %>
              </td>
              <td>
                <%= link_to "Details", admin_audit_log_path(version) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p>No audit logs found matching your filters.</p>
    <% end %>

    <% if @pagy.pages > 1 %>
      <div>
        <%== @pagy.series_nav %>
        <div>
          <%== @pagy.info_tag %>
        </div>
      </div>
    <% end %>
  </div>

  <div>
    <%= link_to "← Back to Users", admin_users_path %>
  </div>
</div>
