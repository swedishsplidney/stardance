<% content_for :title, "Audit Log Details" %>
<div data-controller="json-highlight">
  <div>
    <h1>Audit Log Details</h1>
  </div>

  <div>
    <h3>Event Information</h3>

    <div>
      <div>
        <span>Timestamp</span>
        <span>
          <%= @version.created_at.strftime("%b %d, %Y at %H:%M:%S %Z") %>
        </span>
      </div>

      <div>
        <span>User</span>
        <span>
          <% if @version.whodunnit.present? %>
            <% user = User.find_by(id: @version.whodunnit) %>
            <% if user %>
              <div>
                <img src="<%= user.avatar %>" alt="">
                <span><%= user.display_name %></span>
                <%= link_to "View User", admin_user_path(user) %>
              </div>
            <% else %>
              <span>User #<%= @version.whodunnit %></span>
            <% end %>
          <% else %>
            <span>System</span>
          <% end %>
        </span>
      </div>

      <div>
        <span>Action</span>
        <span>
          <span><%= @version.event %></span>
        </span>
      </div>

      <div>
        <span>Model</span>
        <span>
          <code><%= @version.item_type %></code>
        </span>
      </div>

      <div>
        <span>Record ID</span>
        <span>
          <% case @version.item_type
             when "User" %>
            <%= link_to "##{@version.item_id}", admin_user_path(@version.item_id) %>
          <% when "Project" %>
            <%= link_to "##{@version.item_id}", admin_project_path(@version.item_id) %>
          <% when "ShopOrder" %>
            <%= link_to "##{@version.item_id}", admin_shop_order_path(@version.item_id) %>
          <% when "ShopItem" %>
            <%= link_to "##{@version.item_id}", admin_shop_item_path(@version.item_id) %>
          <% else %>
            <code>#<%= @version.item_id %></code>
          <% end %>
        </span>
      </div>
    </div>
  </div>

  <% if @version.object_changes.present? %>
    <div>
      <h3>Changes</h3>

      <%
        raw = @version.object_changes
        changes = if raw.is_a?(Hash)
          raw
        elsif raw.is_a?(String)
          YAML.safe_load(raw, permitted_classes: [Symbol, Time, Date, DateTime, BigDecimal, ActiveSupport::TimeWithZone, ActiveSupport::TimeZone]) rescue {}
        else
          {}
        end
      %>

      <table>
        <thead>
          <tr>
            <th>Field</th>
            <th>Before</th>
            <th>After</th>
          </tr>
        </thead>
        <tbody>
          <% sensitive_fields = %w[encrypted_password password_digest frozen_address frozen_address_ciphertext frozen_phone_ciphertext email address ip_address phone phone_number hcb_email] %>
          <% changes.each do |field, values| %>
            <tr>
              <td><code><%= field %></code></td>
              <% if sensitive_fields.include?(field.to_s) %>
                <td><span>🔒 [REDACTED]</span></td>
                <td><span>🔒 [REDACTED]</span></td>
              <% elsif values.is_a?(Array) && values.length == 2 %>
                <td>
                  <% old_val = values[0] %>
                  <% if old_val.is_a?(Hash) || old_val.is_a?(Array) %>
                    <pre data-json-highlight-target="code"><%= JSON.pretty_generate(old_val) %></pre>
                  <% elsif old_val.nil? %>
                    <span>null</span>
                  <% else %>
                    <code><%= old_val.inspect %></code>
                  <% end %>
                </td>
                <td>
                  <% new_val = values[1] %>
                  <% if new_val.is_a?(Hash) || new_val.is_a?(Array) %>
                    <pre data-json-highlight-target="code"><%= JSON.pretty_generate(new_val) %></pre>
                  <% elsif new_val.nil? %>
                    <span>null</span>
                  <% else %>
                    <code><%= new_val.inspect %></code>
                  <% end %>
                </td>
              <% else %>
                <td colspan="2">
                  <code><%= values %></code>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <% if @version.object.present? %>
    <div>
      <h3>Previous State</h3>
      <p>Complete object snapshot before this change</p>

      <%
        raw_obj = @version.object
        parsed_obj = if raw_obj.is_a?(Hash)
          raw_obj
        elsif raw_obj.is_a?(String)
          YAML.safe_load(raw_obj, permitted_classes: [Symbol, Time, Date, DateTime, BigDecimal, ActiveSupport::TimeWithZone, ActiveSupport::TimeZone]) rescue raw_obj
        else
          raw_obj
        end
        if parsed_obj.is_a?(Hash)
          sensitive_fields ||= []
          sensitive_fields.each { |f| parsed_obj[f] = "[REDACTED]" if parsed_obj.key?(f) }
        end
      %>
      <pre data-json-highlight-target="code"><%= parsed_obj.is_a?(Hash) ? JSON.pretty_generate(parsed_obj) : parsed_obj %></pre>
    </div>
  <% end %>

  <div>
    <%= link_to "← Back to Audit Logs", admin_audit_logs_path %>
  </div>
</div>
