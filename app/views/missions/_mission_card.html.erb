<%# Locals:
      mission     (Mission)
      badge       (optional String) — small pill in the meta row
      manageable  (optional Boolean) — true when the current viewer is an
                  admin or owner of this mission. On its own this just says
                  "you can manage it"; combined with `!mission.enabled?` it
                  flips on the orange "manager-only visibility" treatment
                  (per docs/branding.md §1.5) — the dashed border and Draft
                  pill only appear when this card is shown to the viewer
                  *because* of their permissions (i.e. a normal user
                  wouldn't see it). Enabled missions are public, so they
                  stay un-marked even if the viewer can also manage them. %>
<% manageable  = local_assigns.fetch(:manageable, false) %>
<% manager_only = manageable && !mission.enabled? %>
<%= link_to mission_path(mission.slug),
            class: ["mission-card",
                    ("mission-card--manageable" if manager_only)].compact.join(" ") do %>
  <div class="mission-card__icon" aria-hidden="true">
    <% if mission.icon.attached? %>
      <%= image_tag mission.icon, alt: "", class: "mission-card__icon-img" %>
    <% else %>
      <%= inline_svg_tag "icons/star_outline.svg", class: "mission-card__icon-svg" %>
    <% end %>
  </div>

  <div class="mission-card__body">
    <h3 class="mission-card__title"><%= mission.name %></h3>
    <p class="mission-card__description">
      <%= truncate(mission.description.to_s, length: 160) %>
    </p>

    <ul class="mission-card__meta" aria-label="Mission meta">
      <% if mission.difficulty.present? %>
        <li class="mission-card__meta-item mission-card__meta-item--difficulty mission-card__meta-item--difficulty-<%= mission.difficulty %>">
          <%= mission.difficulty.titleize %>
        </li>
      <% end %>
      <% card_sections = mission.external_guide? ? mission.guide_sections_count : mission.steps_count %>
      <% if card_sections&.positive? %>
        <li class="mission-card__meta-item">
          <%= card_sections %>-step guide
        </li>
      <% end %>
      <% if local_assigns[:badge].present? %>
        <li class="mission-card__meta-item mission-card__meta-item--badge"><%= badge %></li>
      <% end %>
      <% if manager_only %>
        <li class="mission-card__meta-item mission-card__meta-item--draft" title="This draft is only visible to managers — flip Enabled in the manage page to publish.">Draft</li>
      <% end %>
    </ul>
  </div>

  <span class="mission-card__arrow" aria-hidden="true">→</span>
<% end %>
