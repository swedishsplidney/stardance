<% content_for :title, "Shop" %>
<% content_for :og_title, "Stardance Shop" %>
<% content_for :og_description, "Spend your Stardust on stickers, hardware, and other prizes. Earn Stardust by building projects and voting!" %>
<% content_for :og_image, og_image_url('shop', format: :png) %>

<div class="shop-hub"
     data-controller="shop"
     data-shop-user-region-value="<%= @user_region %>">

  <% if @shop_mode == :preview %>
    <%= render "shop/items/preview_banner" %>
  <% end %>

  <% tutorial_active = @shop_mode == :tutorial && @tutorial_items.values.all?(&:present?) %>
  <% pick_ids = tutorial_active ? @tutorial_items.values.compact.map(&:id) : [] %>

  <% if tutorial_active %>
    <section class="shop-hub__tutorial-card" aria-label="Shop tutorial">
      <div class="shop-hub__tutorial-card-header">
        <h2 class="shop-hub__tutorial-card-title">Complete the tutorial to unlock the shop</h2>
        <p class="shop-hub__tutorial-card-subtitle">Pick one of these to walk through how ordering works.</p>
        <div class="shop-hub__progress-list">
          <div class="shop-hub__progress-item shop-hub__progress-item--done">
            <span class="shop-hub__progress-check">✓</span>
            Create a project
          </div>
          <div class="shop-hub__progress-item shop-hub__progress-item--done">
            <span class="shop-hub__progress-check">✓</span>
            Link Hackatime
          </div>
          <% idv_done = current_user&.identity_submitted? %>
          <div class="shop-hub__progress-item <%= 'shop-hub__progress-item--done' if idv_done %>">
            <span class="shop-hub__progress-check"><%= idv_done ? "✓" : "3" %></span>
            <% if idv_done %>
              Verify your identity
            <% else %>
              <%= button_to "Verify your identity", my_verification_refresh_path(idv_check: 1), method: :post, class: "shop-hub__progress-link", form: { class: "shop-hub__progress-form" } %>
            <% end %>
          </div>
          <% devlog_done = Post.where(user: current_user, postable_type: "Post::Devlog").exists? %>
          <div class="shop-hub__progress-item <%= 'shop-hub__progress-item--done' if devlog_done %>">
            <span class="shop-hub__progress-check"><%= devlog_done ? "✓" : "4" %></span>
            <% if devlog_done %>
              Post a devlog
            <% else %>
              <% first_project = current_user&.projects&.first %>
              <% if first_project %>
                <%= link_to "Post a devlog", project_path(first_project), class: "shop-hub__progress-link" %>
              <% else %>
                Post a devlog
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
      <div class="shop-hub__picks">
        <ul class="shop-hub__picks-row" id="shop-picks">
          <% [ @tutorial_items[:stickers], @tutorial_items[:nothing] ].compact.each do |item| %>
            <li class="shop-hub__items-card">
              <%= render "shop/items/item_card",
                    item: item,
                    mode: :tutorial,
                    region: @user_region,
                    balance: @user_balance,
                    tutorial_item_ids: pick_ids,
                    wishlisted_item_ids: @wishlisted_item_ids,
                    spotlight: false %>
            </li>
          <% end %>
          <li class="shop-hub__picks-cue">
            <%= image_tag "shop/buy_something.png", alt: "", class: "shop-hub__picks-cue-graphic", aria: { hidden: true } %>
            <span class="shop-hub__picks-cue-row">
              <%= inline_svg_tag "icons/tour-arrow.svg", class: "shop-hub__picks-cue-arrow", aria: { hidden: true }, focusable: false %>
              <span class="shop-hub__picks-cue-text">Choose one to go through the tutorial.</span>
            </span>
          </li>
        </ul>
      </div>
      <%# picks_intro_tour overlay removed — the inline cue is clear enough %>
    </section>
  <% end %>

  <div class="shop-hub__layout">
    <header class="shop-hub__topbar">
      <%= form_with url: shop_path, method: :get, local: true, class: "shop-hub__search" do |f| %>
        <%= f.search_field :q,
                           value: params[:q],
                           class: "shop-hub__search-input",
                           placeholder: "Search...",
                           "aria-label": "Search the shop",
                           autocomplete: "off" %>
        <%= inline_svg_tag "icons/search.svg", class: "shop-hub__search-icon" %>
      <% end %>

      <div class="shop-hub__topbar-right">
        <div class="shop-hub__region">
          <%= render DropdownComponent.new(
                label: "Region",
                options: @region_options,
                selected_option: Shop::Regionalizable::REGIONS.dig(@user_region, :name),
                color: :space,
                action: "change->shop#filter"
              ) %>
        </div>

        <% if current_user && Flipper.enabled?(:shop_suggestion_box, current_user) && !current_user.has_dismissed?("shop_suggestion_box") %>
          <button type="button" class="shop-hub__suggest" onclick="document.getElementById('shop-suggestion-modal').showModal()">
            <%= image_tag "Rummage.avif", alt: "", class: "shop-hub__suggest-img" %>
            <span class="shop-hub__suggest-pill">Suggest a prize?</span>
          </button>
        <% end %>
      </div>
    </header>

    <% if @shop_open %>
      <section class="shop-hub__main">
        <ul class="shop-hub__category-grid" aria-label="Shop categories">
          <% @categories.each do |category| %>
            <% category_items = Shop::Categorization.filter(@shop_items, category.slug) %>
            <% category_thumbs = category_items.select { |i| i.image.attached? }.first(3) %>
            <li class="shop-hub__category-tile">
              <%= link_to shop_category_path(category.slug), class: "shop-hub__category-link", data: { turbo: true } do %>
                <div class="shop-hub__category-art" aria-hidden="true">
                  <% if category_thumbs.any? %>
                    <% category_thumbs.each_with_index do |thumb, idx| %>
                      <%= image_tag thumb.image.variant(:carousel_sm), alt: "", class: "shop-hub__category-thumb shop-hub__category-thumb--#{idx}" %>
                    <% end %>
                  <% else %>
                    <span class="shop-hub__category-thumb-placeholder">✦</span>
                  <% end %>
                </div>
                <h2 class="shop-hub__category-name"><%= category.hub_title %></h2>
              <% end %>
            </li>
          <% end %>
        </ul>
      </section>

      <div class="shop-hub__rail">
        <%= render DiscoverRailComponent.new %>
      </div>

      <% if @new_items&.any? %>
        <section class="shop-hub__items shop-hub__items--new" aria-label="New items">
          <div class="shop-hub__items-header">
            <h2 class="shop-hub__section-title">New</h2>
            <%= link_to "See all →", shop_category_path("all"), class: "shop-hub__see-all", data: { turbo: true } %>
          </div>
          <div class="shop-hub__items-scroll" data-controller="horizontal-scroll">
            <button type="button" class="shop-hub__scroll-arrow shop-hub__scroll-arrow--left"
                    data-horizontal-scroll-target="left"
                    data-action="click->horizontal-scroll#scrollLeft"
                    aria-label="Scroll left">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"> <polyline points="15 18 9 12 15 6" /> </svg>
            </button>
            <ul class="shop-hub__items-grid" data-horizontal-scroll-target="track">
              <% @new_items.each do |item| %>
                <li class="shop-hub__items-card">
                  <%= render "shop/items/item_card",
                        item: item,
                        region: @user_region,
                        balance: @user_balance,
                        wishlisted_item_ids: @wishlisted_item_ids %>
                </li>
              <% end %>
            </ul>
            <button type="button" class="shop-hub__scroll-arrow shop-hub__scroll-arrow--right"
                    data-horizontal-scroll-target="right"
                    data-action="click->horizontal-scroll#scrollRight"
                    aria-label="Scroll right">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"> <polyline points="9 18 15 12 9 6" /> </svg>
            </button>
          </div>
        </section>
      <% end %>

      <% if @popular_items&.any? %>
        <section class="shop-hub__items shop-hub__items--popular" aria-label="Popular items">
          <div class="shop-hub__items-header">
            <h2 class="shop-hub__section-title">Popular</h2>
            <%= link_to "See all →", shop_category_path("all"), class: "shop-hub__see-all", data: { turbo: true } %>
          </div>
          <div class="shop-hub__items-scroll" data-controller="horizontal-scroll">
            <button type="button" class="shop-hub__scroll-arrow shop-hub__scroll-arrow--left"
                    data-horizontal-scroll-target="left"
                    data-action="click->horizontal-scroll#scrollLeft"
                    aria-label="Scroll left">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"> <polyline points="15 18 9 12 15 6" /> </svg>
            </button>
            <ul class="shop-hub__items-grid" data-horizontal-scroll-target="track">
              <% @popular_items.each do |item| %>
                <li class="shop-hub__items-card">
                  <%= render "shop/items/item_card",
                        item: item,
                        region: @user_region,
                        balance: @user_balance,
                        wishlisted_item_ids: @wishlisted_item_ids %>
                </li>
              <% end %>
            </ul>
            <button type="button" class="shop-hub__scroll-arrow shop-hub__scroll-arrow--right"
                    data-horizontal-scroll-target="right"
                    data-action="click->horizontal-scroll#scrollRight"
                    aria-label="Scroll right">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"> <polyline points="9 18 15 12 9 6" /> </svg>
            </button>
          </div>
        </section>
      <% end %>
    <% else %>
      <h2 class="shop-hub__closed">The shop is not opened yet!</h2>
    <% end %>
  </div>

  <% if current_user&.admin? %>
    <div class="admin-banner">
      <div class="admin-banner__content">
        <span class="admin-banner__count"><%= @shop_items.count %> items</span>
        <%= link_to "Edit items →", admin_shop_path, class: "admin-banner__link" %>
      </div>
    </div>
  <% end %>
</div>

<%= render "shop/items/suggestion_modal" if current_user && Flipper.enabled?(:shop_suggestion_box, current_user) && !current_user.has_dismissed?("shop_suggestion_box") %>
