<% content_for :title, @category_title %>

<div class="shop-category"
     data-controller="shop"
     data-shop-user-region-value="<%= @user_region %>">

  <header class="shop-category__title-row">
    <span class="shop-category__title-divider shop-category__title-divider--left" aria-hidden="true"></span>
    <h1 class="shop-category__title"><%= @category_title %></h1>
    <span class="shop-category__title-divider shop-category__title-divider--right" aria-hidden="true"></span>
  </header>

  <% if @shop_open %>
    <% if current_user&.admin? %>
      <div class="admin-banner">
        <div class="admin-banner__content">
          <span class="admin-banner__count"><%= @shop_items.count %> items</span>
          <%= link_to "Edit items →", admin_shop_path, class: "admin-banner__link" %>
        </div>
      </div>
    <% end %>

    <div class="shop-category__toolbar">
      <%= form_with url: shop_category_path(@slug), method: :get, local: true, class: "shop-category__search" do |f| %>
        <%= f.search_field :q,
                           value: params[:q],
                           class: "shop-category__search-input",
                           placeholder: "Search...",
                           "aria-label": "Search #{@category_title}",
                           autocomplete: "off",
                           data: { action: "input->shop#search" } %>
        <%= inline_svg_tag "icons/search.svg", class: "shop-category__search-icon" %>
      <% end %>

      <div class="shop-category__filters">
        <%= render DropdownComponent.new(
              label: "Price Range",
              options: [
                { label: "None", value: "none" },
                { label: "0 - 100", value: "0-100" },
                { label: "100 - 500", value: "100-500" },
                { label: "500 - 1000", value: "500-1000" },
                { label: "> 1000", value: "1000+" }
              ],
              selected_option: "None",
              color: :space,
              action: "change->shop#filter"
            ) %>
        <%= render DropdownComponent.new(
              label: "Access",
              options: [ "All", "Available", "Locked" ],
              selected_option: "All",
              color: :space,
              action: "change->shop#filter"
            ) %>
        <%= render DropdownComponent.new(
              label: "Sort by",
              options: [ "Prices", "Alphabetical" ],
              selected_option: "Prices",
              color: :space,
              action: "change->shop#filter"
            ) %>
        <%= render DropdownComponent.new(
              label: "Region",
              options: @region_options,
              selected_option: Shop::Regionalizable::REGIONS.dig(@user_region, :name),
              color: :space,
              action: "change->shop#filter"
            ) %>
      </div>
    </div>

    <%= turbo_frame_tag "shop_items" do %>
      <div class="shop-category__items">
        <% @shop_items.each do |item| %>
          <% if item.image.present? && item.enabled_in_region?(@user_region) %>
            <%= render "shop/items/item_card",
                  item: item,
                  region: @user_region,
                  balance: @user_balance,
                  wishlisted_item_ids: @wishlisted_item_ids %>
          <% end %>
        <% end %>
        <% if @shop_items.empty? %>
          <p class="shop-category__empty">Nothing here yet. Check back soon.</p>
        <% end %>
        <div class="shop__empty" style="display: none;" data-shop-target="empty">
          <p>No items match your filters.</p>
        </div>
      </div>
    <% end %>

    <p class="shop-category__back">
      <%= link_to "← Back to shop", shop_path, class: "shop-category__back-link" %>
    </p>
  <% else %>
    <h2>The shop is not opened yet!</h2>
  <% end %>
</div>

<%= render "shop/items/suggestion_modal" if current_user && Flipper.enabled?(:shop_suggestion_box, current_user) && !current_user.has_dismissed?("shop_suggestion_box") %>
