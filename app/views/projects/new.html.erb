<% content_for :title, "Create new project" %>

<dialog class="project-creation-dialog" id="project-creation-dialog" aria-label="Create new project"
        data-controller="project-creation"
        data-home-url="<%= home_path %>">
    &times;
  </button>

  <div class="project-creation">

    <header class="project-creation__header" aria-label="Create new project">
      <div class="project-creation__divider-row" aria-hidden="true">
        <span class="project-creation__divider-line"></span>
        <svg class="project-creation__divider-sparkle project-creation__divider-sparkle--left" viewBox="206.75 4 28.5 38" xmlns="http://www.w3.org/2000/svg" focusable="false" aria-hidden="true">
          <path d="M219.878 4.56347C220.11 3.49747 221.63 3.49747 221.862 4.56347L224.565 16.998C224.635 17.3195 224.856 17.5872 225.159 17.7162L234.99 21.9063C235.813 22.257 235.813 23.4233 234.99 23.774L225.159 27.9642C224.856 28.0932 224.635 28.3609 224.565 28.6824L221.862 41.1169C221.63 42.1829 220.11 42.1829 219.878 41.1169L217.175 28.6824C217.105 28.3609 216.884 28.0932 216.581 27.9642L206.75 23.774C205.927 23.4233 205.927 22.257 206.75 21.9063L216.581 17.7162C216.884 17.5872 217.105 17.3195 217.175 16.998L219.878 4.56347Z" fill="#EEE7BB" />
        </svg>
        <svg class="project-creation__divider-sparkle project-creation__divider-sparkle--right" viewBox="206.75 4 28.5 38" xmlns="http://www.w3.org/2000/svg" focusable="false" aria-hidden="true">
          <path d="M219.878 4.56347C220.11 3.49747 221.63 3.49747 221.862 4.56347L224.565 16.998C224.635 17.3195 224.856 17.5872 225.159 17.7162L234.99 21.9063C235.813 22.257 235.813 23.4233 234.99 23.774L225.159 27.9642C224.856 28.0932 224.635 28.3609 224.565 28.6824L221.862 41.1169C221.63 42.1829 220.11 42.1829 219.878 41.1169L217.175 28.6824C217.105 28.3609 216.884 28.0932 216.581 27.9642L206.75 23.774C205.927 23.4233 205.927 22.257 206.75 21.9063L216.581 17.7162C216.884 17.5872 217.105 17.3195 217.175 16.998L219.878 4.56347Z" fill="#EEE7BB" />
        </svg>
      </div>
      <div class="project-creation__title-wrap" aria-hidden="true">
        <span class="project-creation__title-fade"></span>
        <h1 class="project-creation__title">Create new project</h1>
      </div>
    </header>

    <section class="project-creation__section" aria-labelledby="project-creation-missions-heading">
      <p class="project-creation__tagline">
        Earn exclusive prizes by completing a mission
          — plus free stickers &amp; a shot at the <a href="<%= raffle_base_url %>/">GPU raffle</a>
      </p>

      <div class="project-creation__heading-row">
        <h2 id="project-creation-missions-heading" class="project-creation__section-heading">Mission</h2>
        <%= link_to "See all →", missions_path, class: "project-creation__see-all" %>
      </div>

      <% if @missions.any? %>
        <div class="project-creation__rail">
          <% @missions.each do |mission| %>
            <div class="project-creation__card">
              <div class="project-creation__card-media">
                <% if mission.banner.attached? %>
                  <%= image_tag mission.banner, alt: "", class: "project-creation__card-image" %>
                <% elsif mission.icon.attached? %>
                  <%= image_tag mission.icon, alt: "", class: "project-creation__card-icon-lg" %>
                <% else %>
                  <div class="project-creation__card-placeholder"></div>
                <% end %>
              </div>

              <div class="project-creation__card-body">
                <h3 class="project-creation__card-title"><%= mission.name %></h3>
                <p class="project-creation__card-description"><%= truncate(mission.description.to_s, length: 100) %></p>

                <div class="project-creation__card-actions">
                  <%= form_with url: projects_path, method: :post, data: { turbo_frame: "_top" } do |f| %>
                    <%= hidden_field_tag :mission_slug, mission.slug %>
                    <%= hidden_field_tag "project[title]", "Untitled" %>
                    <%= f.button type: :submit, class: "project-creation__card-create-btn" do %>
                      Create
                    <% end %>
                  <% end %>

                  <%= link_to "Details →", mission_path(mission.slug), class: "project-creation__card-details-link" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="project-creation__no-missions">Woah there explorer! Looks like you've already seen the whole universe (no more missions are available).</p>
      <% end %>
    </section>

    <div class="project-creation__or" aria-hidden="true">OR, YOU CAN ALSO</div>

    <section class="project-creation__blank-section" aria-labelledby="project-creation-blank-heading"
             data-controller="project-builder">
      <h2 id="project-creation-blank-heading" class="project-creation__section-heading">Make anything you want</h2>

      <div class="project-creation__blank-buttons">
        <%= form_with url: projects_path, method: :post, data: { turbo_frame: "_top" } do |f| %>
          <%= hidden_field_tag "project[title]", "Untitled" %>
          <%= f.button type: :submit, class: "project-creation__blank-btn" do %>
            New software project +
          <% end %>
        <% end %>

        <% if Flipper.enabled?(:hardware_flow) %>
        <button type="button"
                class="project-creation__blank-btn project-creation__blank-btn--hardware"
                data-action="project-builder#toggle"
                data-project-builder-target="hardwareBtn"
                aria-expanded="false"
                aria-controls="project-creation-stage-chooser">
          New hardware project +
        </button>
        <% end %>
      </div>

      <% if Flipper.enabled?(:hardware_flow) %>
      <div id="project-creation-stage-chooser"
           class="project-creation__stage-chooser"
           data-project-builder-target="chooser"
           inert>
        <div class="project-creation__stage-chooser-inner">
          <%= form_with url: projects_path, method: :post, data: { turbo_frame: "_top" }, class: "project-creation__stage-form" do %>
            <%= hidden_field_tag "project[title]", "Untitled" %>
            <%= hidden_field_tag "project[hardware_stage]", "design" %>
            <button type="submit" class="project-creation__stage-option">
              <span class="project-creation__stage-label">I need Funding</span>
              <span class="project-creation__stage-title">I need funding to buy parts for my project</span>
              <span class="project-creation__stage-subtext">Submit your design and we'll fund your build</span>
            </button>
          <% end %>

          <%= form_with url: projects_path, method: :post, data: { turbo_frame: "_top" }, class: "project-creation__stage-form" do %>
            <%= hidden_field_tag "project[title]", "Untitled" %>
            <%= hidden_field_tag "project[hardware_stage]", "build" %>
            <button type="submit" class="project-creation__stage-option">
              <span class="project-creation__stage-label">I don't need Funding</span>
              <span class="project-creation__stage-title">I don't need funding for my project</span>
              <span class="project-creation__stage-subtext">I already have my parts and am ready to start building</span>
            </button>
          <% end %>
        </div>
      </div>
    </section>
      <% end %>

  </div>
</dialog>
