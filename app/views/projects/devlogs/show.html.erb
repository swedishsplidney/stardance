<% content_for :title, "Devlog by @#{@post.user&.display_name}" %>
<% content_for :og_title, "@#{@post.user&.display_name} on #{@project.title} | Stardance" %>
<% content_for :og_description, truncate(@devlog.body.to_s, length: 200) %>
<%
  og_first_image = @devlog.attachments.find { |a| a.image? }
  if og_first_image
    content_for :og_image, url_for(og_first_image.variant(:large))
    content_for :twitter_card, "summary_large_image"
  end
%>

<div class="app-layout">
  <main class="app-layout__main devlog-detail" aria-label="Devlog">
    <nav class="devlog-detail__back" aria-label="Back">
      <%= link_to project_path(@project), class: "devlog-detail__back-link" do %>
        <%= inline_svg_tag "icons/chevron-down.svg", class: "devlog-detail__back-arrow", aria: { hidden: true } %>
        <span>Back to <%= @project.title %></span>
      <% end %>
    </nav>

    <div class="devlog-detail__thread">
      <article class="devlog-detail__post">
        <%= render Posts::CardComponent.new(
              post: @post,
              current_user: current_user,
              show_comments: false,
              show_actions: current_user.present?
            ) %>
      </article>

      <section class="devlog-detail__comments" id="comments">
        <header class="devlog-detail__comments-header">
          <h3 class="devlog-detail__comments-heading">
            Comments
            <span class="devlog-detail__comments-count" id="<%= "comments_count_post_devlog_#{@devlog.id}" %>"><%= @devlog.comments_count %></span>
          </h3>
        </header>

        <div class="devlog-detail__comments-list">
          <% if @comments.any? %>
            <%= render partial: "comments/comment", collection: @comments %>
          <% else %>
            <p class="devlog-detail__empty">No comments yet. Be the first!</p>
          <% end %>
        </div>

        <% if current_user %>
          <%= form_with url: devlog_comments_path(@devlog), scope: :comment, class: "devlog-detail__comment-form", local: true do |f| %>
            <div class="devlog-detail__comment-input-row">
              <%= image_tag current_user.avatar, alt: "", class: "devlog-detail__comment-avatar" %>
              <%= f.text_area :body,
                    id: "comment_body",
                    class: "devlog-detail__comment-textarea",
                    placeholder: "Add a comment... (type @ to mention someone)",
                    rows: 1,
                    maxlength: Comment::BODY_MAX_LENGTH,
                    data: { controller: "submit-on-meta-enter mention-autocomplete",
                            action: "keydown->submit-on-meta-enter#submit keydown->mention-autocomplete#onKeydown input->mention-autocomplete#onInput blur->mention-autocomplete#onBlur" } %>
            </div>
            <div class="devlog-detail__comment-actions">
              <%= render ActionButtonComponent.new(
                    text: "Comment",
                    size: :small,
                    type: :submit,
                    variant: :primary,
                    disable_with: "Posting..."
                  ) %>
            </div>
          <% end %>
        <% else %>
          <p class="devlog-detail__sign-in">
            <%= link_to "Sign in", root_path %> to join the conversation.
          </p>
        <% end %>
      </section>
    </div>
  </main>

  <%= render DiscoverRailComponent.new %>
</div>
