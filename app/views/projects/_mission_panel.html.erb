<%# Locals: project (Project), viewer (User or nil — the current viewer),
    variant (:condensed default, or :expanded to preview the next guide step) %>
<%
  viewer  = local_assigns.fetch(:viewer, nil)
  variant = local_assigns.fetch(:variant, :condensed)
  attachment = project.current_mission_attachment
  mission = attachment&.mission
  is_member = viewer && project.users.exists?(id: viewer.id)
%>

<% if mission.present? %>
  <%
    shipped = project.shipped_to_mission?(mission)
    # Guide progress only matters before the first ship; afterwards the mission
    # is "part of" the project and the guide is just a reference link.
    show_progress = !shipped && mission.has_guide?
    if show_progress
      outline  = mission.guide_sections
      total    = outline.length
      # Sections are keyed on mission_step_id (shared across languages).
      # Count only completions whose step is still in the current outline,
      # so `done` can never exceed `total`.
      step_ids = outline.map { |o| o[:mission_step_id] }
      completed_ids = step_ids.any? ?
                        project.mission_section_completions
                               .where(mission_step_id: step_ids)
                               .pluck(:mission_step_id) :
                        []
      done     = completed_ids.length
      all_done = total.positive? && done >= total

      # Expanded variant previews the next unfinished step's walkthrough.
      if variant == :expanded && !all_done
        next_step_id = step_ids.find { |id| completed_ids.exclude?(id) }
        next_step    = next_step_id && mission.steps.where(deleted_at: nil)
                                              .includes(:bodies).find_by(id: next_step_id)
        next_step_body = next_step&.body_for(mission.default_guide&.language)
      end
    end
  %>
  <section class="<%= class_names("mission-panel", "mission-panel--shipped" => shipped) %>" aria-label="Mission progress">
    <header class="mission-panel__header">
      <div class="mission-panel__identity">
        <% if mission.icon.attached? %>
          <div class="mission-panel__icon">
            <%= image_tag mission.icon, alt: "", class: "mission-panel__icon-img" %>
          </div>
        <% end %>
        <div class="mission-panel__heading">
          <p class="mission-panel__eyebrow"><%= shipped ? "Part of mission" : "On a mission" %></p>
          <h2 class="mission-panel__title">
            <%= link_to mission.name, mission_path(mission.slug), class: "mission-panel__title-link" %>
          </h2>
        </div>
      </div>

      <% guide_link = mission.external_guide? ? mission.guide_url : guide_mission_path(mission.slug) %>
      <% guide_target = mission.external_guide? ? "_blank" : nil %>
      <% guide_rel = mission.external_guide? ? "noopener" : nil %>
      <div class="mission-panel__actions">
        <% if mission.has_guide? %>
          <% if shipped %>
            <%= link_to "View guide", guide_link,
                        target: guide_target, rel: guide_rel,
                        data: { turbo: false },
                        class: "action-btn action-btn--small action-btn--secondary" %>
          <% else %>
            <%= link_to (all_done ? "Review guide" : "Continue guide"), guide_link,
                        target: guide_target, rel: guide_rel,
                        data: { turbo: false },
                        class: "action-btn action-btn--small action-btn--primary" %>
          <% end %>
        <% end %>
        <%= link_to "View mission",
                    mission_path(mission.slug),
                    data: { turbo: false },
                    class: "action-btn action-btn--small action-btn--secondary" %>
        <% if is_member && !shipped %>
          <% fallback = project.shipped? ? project.fallback_mission_after_detaching(mission) : nil %>
          <% detach_confirm = fallback ?
               "Detach this project from #{mission.name}? It'll go back to #{fallback.name}." :
               "Detach this project from #{mission.name}?" %>
          <%= button_to "Detach",
                        project_mission_path(project),
                        method: :delete,
                        data: { confirm: detach_confirm },
                        class: "mission-panel__detach" %>
        <% end %>
      </div>
    </header>

    <% if shipped && is_member %>
      <% follow_up_targets = project.follow_up_targets_for(viewer) %>
      <% follow_ups = follow_up_targets[:ready] %>
      <% awaiting_follow_ups = follow_up_targets[:awaiting] %>
      <% if follow_ups.any? || awaiting_follow_ups.any? %>
        <div class="mission-panel__follow-ups">
          <p class="mission-panel__follow-ups-label">Keep this project going — it can continue into a follow-up mission:</p>
          <div class="mission-panel__follow-ups-actions">
            <% follow_ups.each do |follow_up| %>
              <%= button_to "Continue to #{follow_up.name}",
                            project_mission_path(project),
                            method: :post,
                            params: { mission_slug: follow_up.slug },
                            data: { turbo: false, confirm: "Switch this project from #{mission.name} to #{follow_up.name}?" },
                            class: "action-btn action-btn--small action-btn--primary" %>
            <% end %>
            <% awaiting_follow_ups.each do |follow_up| %>
              <%= render ActionButtonComponent.new(
                    text: "Continue to #{follow_up.name}",
                    size: :small,
                    variant: :primary,
                    type: :button,
                    disabled: :soft,
                    data: {
                      controller: "tooltip",
                      tooltip_message_value: "Hang tight! Wait until your ship is approved to start the next mission (but you can start working on it now :))",
                      tooltip_position_value: "top"
                    }
                  ) %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>

    <% if show_progress && total.positive? %>
      <div class="mission-panel__progress">
        <p class="mission-panel__progress-label">
          <strong><%= done %></strong> of <%= total %> sections
          <% if all_done %><span class="mission-panel__progress-pill">complete</span><% end %>
        </p>
        <progress class="mission-panel__progress-bar"
                  max="<%= total %>"
                  value="<%= done %>"></progress>
      </div>
    <% end %>

    <% if variant == :expanded && next_step %>
      <div class="mission-panel__next-step">
        <p class="mission-panel__next-step-label">Up next</p>
        <h3 class="mission-panel__next-step-title"><%= next_step.title %></h3>
        <% if next_step_body.present? %>
          <div class="mission-panel__next-step-body">
            <%= render MarkdownContentComponent.new(markdown: next_step_body, flavor: :guide) %>
          </div>
          <%= link_to "Continue reading →",
                      mission.external_guide? ? mission.guide_url : guide_mission_path(mission.slug, anchor: "step-#{next_step.id}"),
                      target: guide_target, rel: guide_rel,
                      data: { turbo: false },
                      class: "mission-panel__next-step-more" %>
        <% end %>
      </div>
    <% end %>
  </section>
<% end %>
