<% @feed_posts.each_with_index do |post, index| %>
  <% source = @feed_post_sources&.fetch(post, "quality_latest") || "quality_latest" %>
  <% if post.postable_type == "Post::ShipEvent" %>
    <%= render "projects/ship_card",
          post: post,
          project: post.project,
          source: source,
          position: index + 1,
          page: @pagy.page,
          feed_request_id: @feed_request_id %>
  <% else %>
    <%= render Posts::CardComponent.new(
          post: post,
          current_user: current_user,
          source: source,
          position: index + 1,
          page: @pagy.page,
          feed_request_id: @feed_request_id,
          current_user_reposted_post_ids: @reposted_post_ids,
          show_views: @show_post_views
        ) %>
  <% end %>

  <% if @pagy.page == 1 && index.zero? && @recommended_projects&.any? %>
    <%= render Feed::ShelfComponent.new(
          title: "Recommended projects",
          items: @recommended_projects
        ) do |shelf| %>
      <% @recommended_projects.each do |project| %>
        <% shelf.with_item do %>
          <%= render Projects::ShelfCardComponent.new(
                project: project,
                source: "recommended_projects",
                position: @recommended_projects.index(project).to_i + 1,
                feed_request_id: @feed_request_id
              ) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<% if @feed_posts.empty? && @pagy.page == 1 && @pagy.next.nil? %>
  <% if @recommended_projects&.any? %>
    <%= render Feed::ShelfComponent.new(
          title: "Recommended projects",
          items: @recommended_projects
        ) do |shelf| %>
      <% @recommended_projects.each do |project| %>
        <% shelf.with_item do %>
          <%= render Projects::ShelfCardComponent.new(
                project: project,
                source: "recommended_projects",
                position: @recommended_projects.index(project).to_i + 1,
                feed_request_id: @feed_request_id
              ) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <p class="feed-home__empty">
    <% if @current_tab == "following" %>
      Nothing here yet. Follow some people or projects to see their posts here!
    <% elsif current_user.present? %>
      Nothing here yet. Post a devlog or ship your project to start the feed.
    <% else %>
      Nothing here yet. Sign up to start building and see the feed come alive!
    <% end %>
  </p>
<% end %>

<% if @pagy.next %>
  <% pagination_params = (local_assigns[:feed_params] || {}).merge(page: @pagy.next) %>
  <%= turbo_frame_tag "home_feed_page_#{@pagy.next}",
                      src: home_feed_path(pagination_params),
                      loading: :lazy,
                      target: "_top",
                      class: "feed-home__frame" do %>
    <div class="feed-loading" role="status" aria-live="polite">
      <span class="feed-loading__spinner" aria-hidden="true"></span>
      <span class="feed-loading__label">Loading more&hellip;</span>
    </div>
  <% end %>
<% end %>
