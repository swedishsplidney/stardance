# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key
/config/credentials/development.key

# mac os be like
.DS_Store
/app/assets/builds/*
!/app/assets/builds/.keep

/config/credentials/production.key
db/seeds/shop_items.csv
# Ignore key files for decrypting credentials and more.
/config/credentials/*.key

# Ignore files from JetBrains IDEs
/.idea
/node_modules

# Yarn Berry
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

wak.toml

/config/*.key
app/assets/images/achievements/silhouettes/

Procfile.assets
app/controllers/component_previews_controller.rb
app/views/component_previews/buttons.html.erb
app/views/component_previews/index.html.erb
prod_backupgg.dump
prod.dump

# Ferret vector search sidecar database
/db/ferret.sqlite3*
vendor

.venv

staff-search
