#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  # If running the rails server then create or migrate existing database...
  ./bin/rails db:prepare

  # Refresh generated Slack custom emotes for the composer.
  if ! ./bin/rails slack_emotes:import; then
    echo "Slack emote import failed; continuing boot without refreshed emotes"
  fi

  # ...and background the slow avif conversion task.
  nohup ./bin/rake assets:avif >> log/avif_conversion.log 2>&1 &

  # Warm up Ferret search index in the background so the server can start accepting healthchecks.
  # Only heavy on first run — subsequent boots skip unchanged records.
  if [ "$FERRET" = "true" ]; then
    nohup ./bin/rails runner "Rails.application.eager_load!; Ferret.embed_all!" >> log/ferret_embed.log 2>&1 &
  fi
fi

exec "${@}"
